---
import { getAssetUrl } from "../utils/cdn";
import { reader } from "../utils/reader";

const domainsDataCms = await reader.singletons.domains.read();
const domainItems = domainsDataCms?.items ?? [];
const domainConfigs: Record<string, any> = {};
for (const item of domainItems) {
  domainConfigs[item.key] = {
    title: item.title,
    description: item.description,
    themeColor: item.themeColor,
    cassetteSvg: item.cassetteSvg,
    buttonText: item.buttonText || '',
    techIcons: item.techIcons ?? [],
    aois: item.aois ?? [],
  };
}
---

<script is:inline type="application/json" id="domains-phone-data" set:html={JSON.stringify(domainConfigs)}></script>

<style>
  @keyframes slideInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  .domains-mobile-section {
    background-color: #0d0e0d;
  }

  .domains-mobile-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 140px;
    background: linear-gradient(
      180deg,
      rgba(13, 14, 13, 1) 0%,
      rgba(13, 14, 13, 0) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .domain-mobile-bg-layer {
    transform: translateY(18%) scale(1.05);
    will-change: opacity, transform;
  }
</style>

<section
  class="domains-mobile-section min-h-screen relative pt-8 pb-16 px-4 flex flex-col items-center justify-center overflow-hidden"
  style={`background-image: url('${getAssetUrl("/background_pattern.webp")}'); background-size: cover; background-position: center; background-repeat: no-repeat;`}
>
  <!-- Fixed Background Layer -->
  <div
    class="absolute inset-0 z-0 pointer-events-none opacity-0 domain-mobile-bg-layer"
  >
    <img
      src={getAssetUrl("/glow_ball_red.webp")}
      alt=""
      class="w-full h-full object-cover scale-125 will-change-transform transform-gpu"
      style="backface-visibility: hidden;"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div class="relative z-10 w-full flex flex-col items-center">
    <p
      class="mobile-section-subtitle text-[#fefcd9] text-center font-['PolySans_Trial',sans-serif] text-[12px] sm:text-sm font-normal pt-4 max-w-[340px] mb-12 leading-[1.6] opacity-0 animate-[fadeIn_0.8s_ease_forwards] delay-300"
    >
      <span style="display:block; margin-bottom: 0.5rem;">
        Each domain at CSI-VIT is more than a skillset, it's a mindset.
      </span>
      <span style="display:block; margin-bottom: 0.5rem;">
        We build, break, design, analyze, and communicate, not in silos, but in
        sync.
      </span>
      <span style="display:block;">
        Because true innovation happens where disciplines intersect.
      </span>
    </p>

    <div
      class="domains-mobile-grid flex flex-col gap-8 w-full max-w-[400px] items-center"
    >
      <div
        class="mobile-domain-item w-full max-w-[250px] cursor-pointer transition-all duration-300 ease-out hover:scale-105 opacity-0 translate-y-[30px] animate-[slideInUp_0.6s_ease_forwards] delay-100"
        data-domain="tech"
      >
        <img
          src={getAssetUrl("/Cassette_Tech.webp")}
          alt="Tech Development"
          class="mobile-cassette-img w-full h-auto block drop-shadow-[0_4px_8px_rgba(0,0,0,0.3)] rounded-[20px]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div
        class="mobile-domain-item w-full max-w-[250px] cursor-pointer transition-all duration-300 ease-out hover:scale-105 opacity-0 translate-y-[30px] animate-[slideInUp_0.6s_ease_forwards] delay-200"
        data-domain="cc"
      >
        <img
          src={getAssetUrl("/Cassette_cc.webp")}
          alt="Competitive Coding"
          class="mobile-cassette-img w-full h-auto block drop-shadow-[0_4px_8px_rgba(0,0,0,0.3)] rounded-[20px]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div
        class="mobile-domain-item w-full max-w-[250px] cursor-pointer transition-all duration-300 ease-out hover:scale-105 opacity-0 translate-y-[30px] animate-[slideInUp_0.6s_ease_forwards] delay-300"
        data-domain="design"
      >
        <img
          src={getAssetUrl("/Cassette_Design.webp")}
          alt="Design"
          class="mobile-cassette-img w-full h-auto block drop-shadow-[0_4px_8px_rgba(0,0,0,0.3)] rounded-[20px]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div
        class="mobile-domain-item w-full max-w-[250px] cursor-pointer transition-all duration-300 ease-out hover:scale-105 opacity-0 translate-y-[30px] animate-[slideInUp_0.6s_ease_forwards] delay-400"
        data-domain="management"
      >
        <img
          src={getAssetUrl("/Cassette_Management.webp")}
          alt="Management"
          class="mobile-cassette-img w-full h-auto block drop-shadow-[0_4px_8px_rgba(0,0,0,0.3)] rounded-[20px]"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div
        class="mobile-domain-item w-full max-w-[250px] cursor-pointer transition-all duration-300 ease-out hover:scale-105 opacity-0 translate-y-[30px] animate-[slideInUp_0.6s_ease_forwards] delay-500"
        data-domain="research"
      >
        <img
          src={getAssetUrl("/Cassette_Research.webp")}
          alt="Research"
          class="mobile-cassette-img w-full h-auto block drop-shadow-[0_4px_8px_rgba(0,0,0,0.3)] rounded-[20px]"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { getAssetUrl } from "../utils/cdn";

  const domainConfigs = JSON.parse(document.getElementById('domains-phone-data')!.textContent!) as Record<string, any>;

  gsap.registerPlugin(ScrollTrigger);

  // Mobile-optimized domain screen functionality
  function initMobileAnimation() {
    const items = document.querySelectorAll(".mobile-domain-item");
    const bgLayer = document.querySelector(".domain-mobile-bg-layer");

    // Animate background layer
    if (bgLayer) {
      gsap.to(bgLayer, {
        opacity: 0.35,
        duration: 0.8,
        scrollTrigger: {
          trigger: ".domains-mobile-section",
          start: "top 75%",
          end: "bottom 40%",
          toggleActions: "play reverse play reverse",
        },
      });
    }

    items.forEach((item) => {
      // Add click event handler for domain screen
      item.addEventListener("click", () => {
        const domain = item.getAttribute("data-domain");
        if (domain) {
          showMobileDomainScreen(domain);
        }
      });

      // Add touch feedback
      item.addEventListener("touchstart", () => {
        (item as HTMLElement).style.transform = "scale(0.95)";
      });

      item.addEventListener("touchend", () => {
        (item as HTMLElement).style.transform = "scale(1)";
      });
    });
  }

  // Handle browser back button
  window.addEventListener("popstate", (event) => {
    // If we have a domain screen open and the user pressed back (state is now null or not domainScreenOpen)
    const domainScreen = document.getElementById("mobile-domain-screen");
    if (domainScreen) {
      // The user pressed back, so we just animate it closing
      // We pass 'true' to skip history.back() because the browser already did it
      closeMobileDomainScreenInternal();
    }
  });

  // Function to show mobile domain screen
  function showMobileDomainScreen(domain: string) {
    const config = domainConfigs[domain as keyof typeof domainConfigs];
    if (!config) return;

    // Push history state so back button works
    history.pushState(
      { domainScreenOpen: true },
      "",
      window.location.pathname + "#domain-" + domain
    );

    // Hide all cassettes with animation
    const items = document.querySelectorAll(".mobile-domain-item");
    const subtitle = document.querySelector(".mobile-section-subtitle");
    const domainsSection = document.querySelector(".domains-mobile-section");

    // Create smooth exit animation for cassettes
    items.forEach((item, index) => {
      setTimeout(() => {
        (item as HTMLElement).style.transition =
          "opacity 0.3s ease, transform 0.3s ease";
        (item as HTMLElement).style.opacity = "0";
        (item as HTMLElement).style.transform = "translateY(-20px) scale(0.9)";
      }, index * 50);
    });

    // Hide subtitle
    if (subtitle) {
      setTimeout(() => {
        (subtitle as HTMLElement).style.transition = "opacity 0.3s ease";
        (subtitle as HTMLElement).style.opacity = "0";
      }, 100);
    }

    // Create mobile domain screen HTML after cassettes fade
    setTimeout(() => {
      const mobileDomainScreenHTML = createMobileDomainScreenContent(config);

      // Insert the domain screen
      const domainScreenDiv = document.createElement("div");
      domainScreenDiv.id = "mobile-domain-screen";
      domainScreenDiv.className = "fixed inset-0 z-50 overflow-y-auto";
      domainScreenDiv.style.scrollbarWidth = "none";
      (domainScreenDiv.style as any).msOverflowStyle = "none";
      domainScreenDiv.innerHTML = mobileDomainScreenHTML;

      // Add webkit scrollbar hiding
      const style = document.createElement("style");
      style.textContent = `
                #mobile-domain-screen::-webkit-scrollbar {
                    display: none;
                }
            `;
      document.head.appendChild(style);

      document.body.appendChild(domainScreenDiv);

      // Mobile entrance animation
      (domainScreenDiv as HTMLElement).style.opacity = "0";
      (domainScreenDiv as HTMLElement).style.transform = "translateY(20px)";

      setTimeout(() => {
        (domainScreenDiv as HTMLElement).style.transition =
          "opacity 0.3s ease, transform 0.3s ease";
        (domainScreenDiv as HTMLElement).style.opacity = "1";
        (domainScreenDiv as HTMLElement).style.transform = "translateY(0)";
      }, 10);
    }, 400);
  }

  // Function to create mobile domain screen content
  function createMobileDomainScreenContent(config: any) {
    const themeColors = {
      tech: "#9B51E0",
      cc: "#B4E35B",
      design: "#FF7777",
      research: "#9AF3FF",
      management: "#008080",
      competitive: "#42CD9D",
    };

    const themeHex =
      themeColors[config.themeColor as keyof typeof themeColors] ||
      themeColors.tech;

    return `
            <div class="min-h-screen text-white" style="background-color: #000000; background-image: url('${getAssetUrl("/background_pattern.webp")}'); background-size: cover; background-position: center; background-repeat: no-repeat;">
                <!-- Mobile Back Button -->
                <div class="fixed top-4 right-4 z-50">
                    <button 
                        onclick="hideMobileDomainScreen()"
                        class="relative w-10 h-10 flex items-center justify-center hover:opacity-80 transition-opacity"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 50 50" fill="none" class="absolute">
                            <circle cx="25" cy="25" r="19.5" stroke="#FEFCD9"/>
                        </svg>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="relative z-10">
                            <path d="M3 19V5" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M13 6L7 12L13 18" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M7 12H21" stroke="#FEFCD9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>

                <!-- Mobile Hero Section with Theme Header -->
                <div class="pt-16 pb-8 px-4">
                    <!-- Mobile Main Title Card -->
                    <div class="mx-auto max-w-xs mb-8 relative">
                        <!-- Mobile SVG Background (using desktop path scaled) -->
                        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="80" viewBox="0 0 1389 178" fill="none" class="w-full">
                            <path d="M88 1.5H1301C1348.77 1.5 1387.5 40.2274 1387.5 88V90C1387.5 137.773 1348.77 176.5 1301 176.5H88C40.2274 176.5 1.5 137.773 1.5 90V88C1.5 40.2274 40.2274 1.5 88 1.5Z" fill="${themeHex}" stroke="#FEFCD9" stroke-width="20"/>
                        </svg>
                        
                        <!-- Mobile Content overlay -->
                        <div class="absolute inset-0 flex items-center justify-center p-3">
                            <!-- Mobile Decorative Elements -->
                            <div class="absolute left-3 top-1/2 -translate-y-1/2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 124 124" fill="none" class="animate-spin" style="animation-duration: 8s;">
                                    <circle cx="62" cy="62" r="57.5" stroke="#1E1E1E" stroke-width="3"/>
                                    <path d="M61.6582 18C67.7102 18 73.4766 19.2231 78.7246 21.4336L73.4238 30.6182L82.9629 36.126L88.2588 26.9512C97.4504 33.9379 103.81 44.4557 105.314 56.4844H94.7051V67.5H105.316C103.815 79.5413 97.4473 90.0689 88.2441 97.0586L82.9473 87.8828L73.4082 93.3906L78.709 102.572C73.4651 104.779 67.7043 106 61.6582 106C55.6035 106 49.8348 104.776 44.585 102.563L49.8945 93.3672L40.3555 87.8594L35.0527 97.0439C25.8603 90.0541 19.5005 79.5326 18 67.5H28.6123V56.4844H18.002C19.5071 44.4491 25.8735 33.9262 35.0732 26.9395L40.3721 36.1172L49.9121 30.6104L44.6094 21.4258C49.8527 19.2199 55.6129 18.0001 61.6582 18Z" fill="#1E1E1E"/>
                                </svg>
                            </div>
                            
                            <div class="absolute right-3 top-1/2 -translate-y-1/2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 124 124" fill="none" class="animate-spin" style="animation-duration: 8s;">
                                    <circle cx="62" cy="62" r="57.5" stroke="#1E1E1E" stroke-width="3"/>
                                    <path d="M61.6582 18C67.7102 18 73.4766 19.2231 78.7246 21.4336L73.4238 30.6182L82.9629 36.126L88.2588 26.9512C97.4504 33.9379 103.81 44.4557 105.314 56.4844H94.7051V67.5H105.316C103.815 79.5413 97.4473 90.0689 88.2441 97.0586L82.9473 87.8828L73.4082 93.3906L78.709 102.572C73.4651 104.779 67.7043 106 61.6582 106C55.6035 106 49.8348 104.776 44.585 102.563L49.8945 93.3672L40.3555 87.8594L35.0527 97.0439C25.8603 90.0541 19.5005 79.5326 18 67.5H28.6123V56.4844H18.002C19.5071 44.4491 25.8735 33.9262 35.0732 26.9395L40.3721 36.1172L49.9121 30.6104L44.6094 21.4258C49.8527 19.2199 55.6129 18.0001 61.6582 18Z" fill="#1E1E1E"/>
                                </svg>
                            </div>

                            <!-- Mobile Domain Title -->
                            <div class="text-center">
                                <h1 class="${config.title === "COMPETITIVE CODING" ? "text-lg" : "text-xl"} font-normal text-[#1E1E1E] tracking-wider">
                                    ${config.title}
                                </h1>
                            </div>
                        </div>
                    </div>

                    <!-- Mobile Tech Stack Icons -->
                    ${
                      config.techIcons.length > 0
                        ? `
                        <div class="flex justify-center items-center gap-4 mb-8 flex-wrap px-4">
                            ${config.techIcons
                              .map(
                                (icon: any) => `
                                <div class="flex items-center justify-center hover:scale-110 transition-transform duration-300">
                                    <img 
                                        src="${getAssetUrl(icon.src)}" 
                                        alt="${icon.alt}" 
                                        class="w-8 h-8 grayscale hover:grayscale-0 transition-all duration-300 opacity-70 hover:opacity-100" 
                                        loading="lazy"
                                        decoding="async"
                                    />
                                </div>
                            `
                              )
                              .join("")}
                        </div>
                    `
                        : ""
                    }

                    <!-- Mobile Description -->
                    <div class="max-w-sm mx-auto text-center mb-8">
                        <p class="text-[#FEFCD9] text-sm leading-relaxed">
                            ${config.description}
                        </p>
                    </div>

                    <!-- Mobile Projects Button -->
                    ${
                      config.buttonText
                        ? `
                    <div class="flex justify-center mb-8">
                        <button 
                            class="flex justify-center items-center px-6 py-3 h-[40px] rounded-[25px] border border-[#FEFCD9] font-medium hover:shadow-lg transition-shadow whitespace-nowrap ${
                              config.themeColor === "competitive" ||
                              config.themeColor === "research" ||
                              config.themeColor === "tech"
                                ? "text-black"
                                : "text-white"
                            }"
                            style="background-color: ${themeHex}"
                        >
                            ${config.buttonText}
                        </button>
                    </div>
                    `
                        : ""
                    }

                    <!-- Mobile AOIs -->
                    ${
                      config.aois && config.aois.length > 0
                        ? `
                        <div class="flex justify-center items-center gap-4 mb-8 flex-wrap px-6">
                            ${config.aois
                              .map(
                                (aoi: any) => `
                                <div class="flex flex-col items-center justify-center gap-2 hover:scale-105 transition-transform duration-300">
                                    <img 
                                        src="${getAssetUrl(aoi.src)}" 
                                        alt="${aoi.alt}" 
                                        class="w-24 h-24 object-contain" 
                                        loading="lazy"
                                        decoding="async"
                                    />
                                    <span class="text-[#FEFCD9] text-[11px] font-medium tracking-wide text-center">${aoi.alt}</span>
                                </div>
                            `
                              )
                              .join("")}
                        </div>
                    `
                        : ""
                    }
                </div>
            </div>
        `;
  }

  // Called when the X / back button in the UI is clicked
  (window as any).hideMobileDomainScreen = function () {
    // Manually trigger history back, which will trigger the popstate listener, which calls internal close
    history.back();
  };

  // Internal close function (doesn't touch history)
  function closeMobileDomainScreenInternal() {
    const domainScreen = document.getElementById("mobile-domain-screen");

    if (domainScreen) {
      (domainScreen as HTMLElement).style.transition =
        "opacity 0.3s ease, transform 0.3s ease";
      (domainScreen as HTMLElement).style.opacity = "0";
      (domainScreen as HTMLElement).style.transform = "translateY(20px)";

      setTimeout(() => {
        domainScreen.remove();

        // Restore cassettes and subtitle with staggered animation
        const items = document.querySelectorAll(".mobile-domain-item");
        const subtitle = document.querySelector(".mobile-section-subtitle");

        // Show subtitle first
        if (subtitle) {
          (subtitle as HTMLElement).style.transition = "opacity 0.4s ease";
          (subtitle as HTMLElement).style.opacity = "1";
        }

        // Then show cassettes with stagger
        items.forEach((item, index) => {
          setTimeout(
            () => {
              (item as HTMLElement).style.transition =
                "opacity 0.4s ease, transform 0.4s ease";
              (item as HTMLElement).style.opacity = "1";
              (item as HTMLElement).style.transform = "translateY(0) scale(1)";
            },
            index * 100 + 200
          );
        });
      }, 300);
    }
  }

  // Initialize mobile animations
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMobileAnimation);
  } else {
    initMobileAnimation();
  }
</script>
