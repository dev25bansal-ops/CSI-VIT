---
import { getAssetUrl } from "../utils/cdn";
const fallbackEmail = "hello@csivitchennai.in";
const rawEndpoint = (import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "").trim();
const formAction = rawEndpoint ? undefined : `mailto:${fallbackEmail}`;
---

<section class="w-full px-4 py-12">
  <div
    class="mx-auto max-w-xl rounded-[32px] border border-white/15 bg-white/[0.04] p-6 text-white shadow-[0_15px_45px_rgba(0,0,0,0.45)]"
  >
    <div class="mb-5 text-center">
      <h3 class="text-3xl font-semibold uppercase">Contact us!</h3>
      <p class="mt-2 text-xs uppercase tracking-[0.45em] text-white/60">
        Say Hello!
      </p>
    </div>

    <form
      class="flex flex-col gap-4 text-sm"
      method="POST"
      id="contact-form-mobile"
    >
      <div class="flex flex-col gap-4 sm:flex-row sm:gap-3">
        <label
          class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
        >
          First Name
          <input
            type="text"
            name="firstName"
            required
            class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
          />
        </label>
        <label
          class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
        >
          Last Name
          <input
            type="text"
            name="lastName"
            class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
          />
        </label>
      </div>

      <label
        class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
      >
        Email
        <input
          type="email"
          name="email"
          required
          class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
        />
      </label>

      <label
        class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
      >
        Phone
        <input
          type="tel"
          name="phone"
          inputmode="tel"
          pattern="^[0-9+()\s-]{7,}$"
          class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
        />
      </label>

      <label
        class="flex flex-col gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-white/60"
      >
        Message
        <textarea
          name="message"
          rows="4"
          required
          class="rounded-2xl border-2 border-dashed border-white/35 bg-transparent px-4 py-3 text-base text-white outline-none transition focus:border-[#F95F4A]"
        ></textarea>
      </label>

      <button
        type="submit"
        class="mt-2 inline-flex items-center justify-center rounded-full border border-white/60 px-8 py-3 text-lg font-semibold uppercase tracking-[0.35em] text-white transition hover:bg-white/10"
      >
        Submit
      </button>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById(
    "contact-form-mobile"
  ) as HTMLFormElement;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalBtnText = submitBtn ? submitBtn.innerHTML : "Submit";
      const setSubmitting = (submitting: boolean) => {
        if (!submitBtn) return;
        submitBtn.innerHTML = submitting ? "Sending..." : originalBtnText;
        (submitBtn as HTMLButtonElement).disabled = submitting;
      };

      setSubmitting(true);

      const formData = new FormData(form);
      // Handle radio buttons specifically if needed, but Object.fromEntries handles it if checked
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          form.reset();
        } else {
          const resData = await response.json();
          console.warn(`Failed to send message: ${resData.message || "Error"}`);
        }
      } catch (error) {
        console.error("Error:", error);
      } finally {
        setSubmitting(false);
      }
    });
  }
</script>
