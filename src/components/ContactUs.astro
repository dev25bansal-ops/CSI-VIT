---

---

<section class="laptop-section relative w-full h-[300vh]">
  <div
    class="sticky top-0 left-0 w-full h-screen flex items-center justify-center overflow-hidden"
  >
    <canvas
      id="laptop-canvas"
      class="w-[80%] h-[80%] object-contain brightness-125"></canvas>
    <div
      class="contact-heading absolute top-[25%] left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-center z-10 opacity-100 pointer-events-none"
    >
      <div
        class="justify-start text-white text-5xl font-semibold font-['PolySans_Trial'] uppercase"
      >
        Contact us!
      </div>
    </div>

    <!-- Contact Form Overlay -->
    <div
      class="contact-form-overlay absolute top-[8%] left-[11%] w-[78%] h-[72%] z-20 opacity-0 pointer-events-none flex flex-col items-center justify-center"
    >
      <div class="flex flex-col items-center text-black mb-1">
        <div
          class="text-center justify-start text-stone-900 text-2xl font-bold font-['PolySans_Trial']"
        >
          Say Hello!
        </div>
      </div>

      <form
        class="contact-form pointer-events-auto mt-4 flex w-full max-w-[50%] flex-col gap-4 text-xs text-black px-4"
        method="POST"
        id="contact-form-desktop"
      >
        <div class="contact-grid grid gap-4 sm:grid-cols-2">
          <label
            class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
          >
            First Name
            <input
              type="text"
              name="firstName"
              required
              class="contact-input"
            />
          </label>
          <label
            class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
          >
            Last Name
            <input type="text" name="lastName" class="contact-input" />
          </label>
        </div>

        <div class="contact-grid grid gap-4 sm:grid-cols-2">
          <label
            class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
          >
            Email
            <input type="email" name="email" required class="contact-input" />
          </label>
          <label
            class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
          >
            Phone
            <input
              type="tel"
              name="phone"
              inputmode="tel"
              pattern="^[0-9+()\s-]{7,}$"
              class="contact-input"
            />
          </label>
        </div>

        <label
          class="flex flex-col gap-2 text-[8px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-[10px]"
        >
          Message
          <textarea
            name="message"
            rows="2"
            required
            class="contact-input resize-none py-2.5"></textarea>
        </label>

        <div class="flex flex-col items-center gap-4 mt-4">
          <div
            class="w-40 h-10 bg-stone-900 rounded-[200px] flex items-center justify-center overflow-hidden"
          >
            <button
              type="submit"
              class="group inline-flex items-center justify-center gap-2 w-full h-full text-lg font-light text-[#ffeead] sm:text-xl hover:bg-white/5 transition-colors"
            >
              Submit
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-input {
    border-radius: 0.75rem;
    border: 1.5px dashed #050505;
    background: transparent;
    padding: 0.6rem 0.8rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #050505;
    outline: none;
    transition: border 0.2s ease;
    width: 100%;
  }

  .contact-input:focus {
    border-color: #f95f4a;
  }

  /* Adjust form layout for the laptop screen size */
  .contact-form {
    height: auto;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { getAssetUrl } from "../utils/cdn";

  gsap.registerPlugin(ScrollTrigger);

  const canvas = document.querySelector("#laptop-canvas") as HTMLCanvasElement;
  const context = canvas?.getContext("2d", { alpha: true });
  const section = document.querySelector(".laptop-section");

  const frameCount = 125;
  const narrowQuery = "(max-width: 1024px)";
  let maxCacheSize = frameCount;
  let preloadRadius = 8;
  const pendingFrames = new Set<number>();
  const frameCache = new Map<number, HTMLImageElement>();
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  const laptop = {
    frame: 0,
  };

  const updatePerfSettings = () => {
    const isNarrow = window.matchMedia(narrowQuery).matches;
    maxCacheSize = isNarrow ? Math.min(12, frameCount) : frameCount;
    preloadRadius = isNarrow ? 3 : 8;
  };

  const currentFrame = (index: number) =>
    getAssetUrl(
      `/outputFolder/frame_${(index + 1).toString().padStart(4, "0")}.png`
    );

  const clampFrame = (index: number) =>
    Math.max(0, Math.min(frameCount - 1, Math.round(index)));

  const resizeCanvas = () => {
    if (!canvas || !context) return;
    updatePerfSettings();
    const rect = canvas.getBoundingClientRect();
    if (!rect.width || !rect.height) return;
    const maxDpr = window.matchMedia(narrowQuery).matches
      ? 1.25
      : 1.5;
    const dpr = Math.min(window.devicePixelRatio || 1, maxDpr);
    const width = Math.round(rect.width * dpr);
    const height = Math.round(rect.height * dpr);
    if (canvas.width !== width || canvas.height !== height) {
      canvas.width = width;
      canvas.height = height;
    }
  };

  const trimCache = (center: number) => {
    if (maxCacheSize >= frameCount || frameCache.size <= maxCacheSize) return;
    const keys = Array.from(frameCache.keys()).sort(
      (a, b) => Math.abs(a - center) - Math.abs(b - center)
    );
    const keep = new Set(keys.slice(0, maxCacheSize));
    for (const key of frameCache.keys()) {
      if (!keep.has(key)) frameCache.delete(key);
    }
  };

  const loadFrame = async (index: number) => {
    const clampedIndex = clampFrame(index);
    const cached = frameCache.get(clampedIndex);
    if (cached) return cached;
    if (pendingFrames.has(clampedIndex)) return null;
    pendingFrames.add(clampedIndex);

    const img = new Image();
    img.decoding = "async";
    img.src = currentFrame(clampedIndex);
    const awaitLoad = () =>
      new Promise((resolve) => {
        if (img.complete) {
          resolve(null);
          return;
        }
        img.onload = () => resolve(null);
        img.onerror = () => resolve(null);
      });

    if (typeof img.decode === "function") {
      try {
        await img.decode();
      } catch {
        await awaitLoad();
      }
    } else {
      await awaitLoad();
    }

    pendingFrames.delete(clampedIndex);
    frameCache.set(clampedIndex, img);
    trimCache(clampedIndex);
    return img;
  };

  const queueFrames = (center: number) => {
    const start = Math.max(0, center - preloadRadius);
    const end = Math.min(frameCount - 1, center + preloadRadius);
    for (let i = start; i <= end; i++) {
      void loadFrame(i);
    }
  };

  let preloadAllScheduled = false;
  const preloadAllFrames = async () => {
    const concurrency = Math.min(6, frameCount);
    let nextIndex = 0;

    const worker = async () => {
      while (nextIndex < frameCount) {
        const index = nextIndex;
        nextIndex += 1;
        await loadFrame(index);
      }
    };

    await Promise.all(
      Array.from({ length: concurrency }, () => worker())
    );
  };

  const schedulePreloadAll = () => {
    if (prefersReducedMotion || preloadAllScheduled) return;
    if (window.matchMedia(narrowQuery).matches) return;
    preloadAllScheduled = true;
    window.setTimeout(() => {
      void preloadAllFrames();
    }, 200);
  };

  let lastRenderedFrame = -1;
  let lastCanvasWidth = 0;
  let lastCanvasHeight = 0;

  const render = () => {
    if (!context || !canvas) return;
    const frame = clampFrame(laptop.frame);
    const img = frameCache.get(frame);
    if (!img) {
      void loadFrame(frame).then((loaded) => {
        if (loaded && frame === clampFrame(laptop.frame)) render();
      });
      return;
    }

    if (
      frame === lastRenderedFrame &&
      canvas.width === lastCanvasWidth &&
      canvas.height === lastCanvasHeight
    ) {
      return;
    }

    lastRenderedFrame = frame;
    lastCanvasWidth = canvas.width;
    lastCanvasHeight = canvas.height;
    context.clearRect(0, 0, canvas.width, canvas.height);
    context.drawImage(img, 0, 0, canvas.width, canvas.height);
    queueFrames(frame);
  };

  const initSequence = async () => {
    if (!canvas || !context) return;
    resizeCanvas();
    await loadFrame(0);
    render();
    schedulePreloadAll();

    if (prefersReducedMotion) {
      const formOverlay = document.querySelector(
        ".contact-form-overlay"
      ) as HTMLElement | null;
      if (formOverlay) {
        formOverlay.style.opacity = "1";
        formOverlay.style.pointerEvents = "auto";
      }
      const heading = document.querySelector(
        ".contact-heading"
      ) as HTMLElement | null;
      if (heading) {
        heading.style.opacity = "0";
        heading.style.transform = "translateY(-50px)";
      }
      return;
    }

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".laptop-section",
        start: "top top",
        end: "bottom bottom",
        scrub: 0.5,
      },
    });

    tl.to(laptop, {
      frame: 0,
      duration: 0.5,
      onUpdate: render,
    })
      .to(laptop, {
        frame: frameCount - 1,
        snap: "frame",
        ease: "none",
        duration: 2,
        onUpdate: render,
      })
      .to(
        ".contact-heading",
        {
          opacity: 0,
          y: -50,
          duration: (20 / frameCount) * 2,
          ease: "none",
        },
        `<+${(40 / frameCount) * 2}`
      )
      .to(
        ".contact-form-overlay",
        {
          opacity: 1,
          pointerEvents: "auto",
          duration: 0.5,
          ease: "power2.inOut",
        },
        `<+${(40 / frameCount) * 2}`
      );
  };

  let started = false;
  const startWhenVisible = () => {
    if (started) return;
    started = true;
    initSequence();
  };

  if (section && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          startWhenVisible();
          observer.disconnect();
        }
      },
      { rootMargin: "200px" }
    );
    observer.observe(section);
  } else {
    startWhenVisible();
  }

  window.addEventListener("resize", () => {
    resizeCanvas();
    lastRenderedFrame = -1;
    render();
  });

  // Form handling
  const form = document.getElementById(
    "contact-form-desktop"
  ) as HTMLFormElement;
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalBtnText = submitBtn ? submitBtn.innerHTML : "Submit";
      const setSubmitting = (submitting: boolean) => {
        if (!submitBtn) return;
        submitBtn.innerHTML = submitting ? "Sending..." : originalBtnText;
        (submitBtn as HTMLButtonElement).disabled = submitting;
      };

      setSubmitting(true);

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch("/api/contact", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          form.reset();
        } else {
          const resData = await response.json();
          console.warn(
            `Failed to send message: ${resData.message || "Unknown error"}`
          );
        }
      } catch (error) {
        console.error("Error:", error);
      } finally {
        setSubmitting(false);
      }
    });
  }
</script>
