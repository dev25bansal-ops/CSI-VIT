---
import { reader } from "../utils/reader";
import { getAssetUrl } from "../utils/cdn";
import EventDetails from "./EventDetails.astro";

const eventsData = await reader.singletons.events.read();
const cassetteImages = eventsData?.cassetteImages ?? [];
// Reconstruct the key-based info object from the CMS array
const infoArray = eventsData?.info ?? [];
const info: Record<string, { title: string; site: string; description: string }> = {};
for (const item of infoArray) {
  info[item.key] = { title: item.title, site: item.site ?? '', description: item.description };
}

interface Project {
  caption: string;
  site: string;
  src: string;
  description?: string;
}

let projects: Project[] = [];
let pens: Project[] = [];

// Create dummy projects
cassetteImages.forEach((src, i) => {
  const index = i + 1;
  const key = `Event${index}` as keyof typeof info;
  const project = info[key];

  if (project) {
    projects.push({
      caption: `${project.title}`,
      site: project.site,
      src: getAssetUrl(src),
      description: project.description,
    });
  }
});

function shuffle(array: Project[]) {
  let currentIndex = array.length;
  while (currentIndex != 0) {
    let randomIndex = Math.floor(Math.random() * currentIndex);
    currentIndex--;
    [array[currentIndex], array[randomIndex]] = [
      array[randomIndex],
      array[currentIndex],
    ];
  }
}

shuffle(projects);

// Add pens in between projects regularly
let works: Project[] = [];
let chunkSize = Math.floor(projects.length / (pens.length || 1));
let i = 0;
let j = 0;
while (i < projects.length) {
  works.push(projects[i]);
  if (pens.length > 0 && j < pens.length && (i + 1) % chunkSize === 0) {
    works.push(pens[j]);
    j++;
  }
  i++;
}

const worksHeight = works.length * 50;
const worksHeightMobile = works.length * 45;
---

<section
  id="work"
  class="s-work"
  data-intersect
  style={`--height: ${worksHeight}svh; --height-mobile: ${worksHeightMobile}svh;`}
>
  <div class="s__outer">
    <div class="s__inner js-container">
      <h2 class="s__title">
        <span class="s__title__inner js-title">
          <span class="s__title__letter js-letter">E</span>
          <span class="s__title__letter js-letter">V</span>
          <span class="s__title__letter js-letter">E</span>
          <span class="s__title__letter js-letter">N</span>
          <span class="s__title__letter js-letter">T</span>
          <span class="s__title__letter js-letter">S</span>
        </span>
      </h2>

      <div class="s__scene js-scene">
        {
          works.map((work, index) => {
            const key =
              Math.random().toString(36).slice(2, 6) +
              "-" +
              String(index).padStart(4, "0") +
              "/" +
              String(works.length).padStart(2, "0");
            return (
              <a-work
                class="s__scene__work s__scene__work--video js-work"
                progress="1"
                style="--progress: 1; cursor: pointer;"
              >
                <div class="a__inner">
                  <a
                    href={work.site}
                    target="_blank"
                    data-title={work.caption}
                    data-description={work.description}
                    data-site={work.site}
                    data-src={work.src}
                  >
                    <img
                      src={work.src}
                      class="a__video js-video"
                      width="1082"
                      height="636"
                      alt={work.caption}
                      loading="lazy"
                      decoding="async"
                    />

                    <div class="a__caption">
                      <div class="a__caption__text">{work.caption}</div>
                      <div class="a__caption__key">#{key}</div>
                    </div>
                  </a>
                </div>
              </a-work>
            );
          })
        }
      </div><!-- .s__scene -->

      <canvas class="s__canvas js-canvas"></canvas>
    </div><!-- .s__inner -->

    <div
      class="s__mask-outer"
      style="pointer-events: none !important; z-index: 10;"
    >
      <div class="s__mask js-mask" style="pointer-events: none !important;">
        <svg
          class="s__mask__svg js-mask-svg"
          style="pointer-events: none !important;"
        >
          <path class="s__mask__path-inner js-mask-path-inner" d=""></path>
          <path class="s__mask__path-outer js-mask-path-outer" d=""></path>
          <path class="s__mask__path-lines js-mask-path-lines" d=""></path>
        </svg>
      </div><!-- .s__mask -->
    </div><!-- .s__mask-outer -->

    <div class="s__ruler js-ruler"></div>
    <EventDetails />
  </div><!-- .s__outer -->
</section>

<script>
  import { gsap } from "gsap";
  import { SlowMo } from "gsap/EasePack";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger, SlowMo);

  // Extend Window interface for custom safe area properties
  declare global {
    interface Window {
      safeWidth?: number;
      safeHeight?: number;
    }
  }

  // --- Utils ---
  class Emitter {
    events: { [key: string]: any[] };
    constructor() {
      this.events = {};
    }
    on(name: string, callback: any, context: any, once = false) {
      if (!this.events[name]) {
        this.events[name] = [];
      }
      let exists = false;
      this.events[name].forEach((object) => {
        if (object.cb === callback && object.context === context) {
          exists = true;
          return;
        }
      });
      if (exists) {
        return;
      }
      this.events[name].push({ cb: callback, context: context, once: once });
    }
    once(name: string, callback: any, context: any) {
      this.on(name, callback, context, true);
    }
    emit(name: string, ...args: any[]) {
      const self = this;
      if (this.events[name]) {
        this.events[name].forEach((object, index) => {
          object.cb.apply(object.context, args);
          if (object.once) {
            delete self.events[name][index];
          }
        });
      }
    }
    off(name: string, callback: any, context: any) {
      const self = this;
      if (this.events[name]) {
        this.events[name].forEach((object, index) => {
          if (object.cb === callback && object.context === context) {
            delete self.events[name][index];
          }
        });
      }
    }
  }
  const emitter = new Emitter();

  class Ticker {
    callbacks: any[];
    delta: number;
    constructor() {
      this.callbacks = [];
      this.delta = 0;
    }
    init() {
      gsap.ticker.add(this.tick.bind(this));
    }
    tick(time: number, delta: number) {
      const self = this;
      this.delta = delta;
      this.callbacks.forEach((object, index) => {
        object.callback.apply(object.context);
        delete self.callbacks[index];
      });
      emitter.emit("tick", time * 1000);
    }
    nextTick(callback: Function, context: any) {
      this.callbacks.push({ callback, context });
    }
  }
  const ticker = new Ticker();
  ticker.init();

  // --- AWork Component ---
  class AWork extends HTMLElement {
    static observedAttributes = ["progress"];
    link!: HTMLAnchorElement;
    video!: HTMLImageElement;
    isPlaying!: boolean;

    connectedCallback() {
      // console.log("AWork connected");
      this.video = this.querySelector(".js-video")!;
      this.link = this.querySelector("a")!;
      this.isPlaying = false;
      this.addEventListener("click", this.onClick.bind(this)); // Attach to self
      this.link.addEventListener("click", (e) => e.stopPropagation()); // Let parent handle? Or just let it bubble?
      // Actually, if we attach to 'this', we don't need to attach to link if link bubbles.
      // But link has href. We want href to work.
    }

    attributeChangedCallback(
      name: string,
      oldValue: string | null,
      newValue: string | null
    ) {
      if (name === "progress") {
        this.style.setProperty("--progress", newValue);
        if (newValue === "1" || newValue === "-1") {
          if (this.isPlaying) {
            this.outView();
          }
        } else {
          if (!this.isPlaying) {
            this.inView();
          }
        }
      }
    }

    inView() {
      this.isPlaying = true;
      this.classList.add("is-inview");
    }

    outView() {
      this.isPlaying = false;
      this.classList.remove("is-inview");
    }

    onClick(event: MouseEvent) {
      // Don't prevent default! We want the link to open.

      // Manually trigger the link if the user clicked the custom element (outside the a tag? shouldn't happen if a fills it)
      // If event.target is the link or inside it, normal behavior proceeds (new tab).
      // We just need to dispatch the modal event.

      const title = this.link.dataset.title;
      const description = this.link.dataset.description;
      const site = this.link.dataset.site;
      const src = this.link.dataset.src;

      const detail = {
        title,
        description,
        site,
        src,
      };

      document.dispatchEvent(
        new CustomEvent("open-event-modal", {
          detail,
        })
      );

      // return false; // Removed to allow link redirect
    }
  }
  if (!customElements.get("a-work")) {
    customElements.define("a-work", AWork);
  }

  // --- Section Logic ---
  interface Ghost {
    el: HTMLElement;
    x: number;
    y: number;
    z: number;
    i: number;
    p: number;
    ap: number;
    mx: number;
    my: number;
  }

  interface Letter {
    el: HTMLElement;
    ghosts: Ghost[];
    width?: number;
    height?: number;
    top?: number;
    left?: number;
    freq: number;
    total: number;
  }

  class Section {
    el: HTMLElement;
    container: HTMLElement;
    ruler: HTMLElement;
    scene: HTMLElement;
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    title: HTMLElement;
    videos: NodeListOf<HTMLImageElement>;

    mask: {
      width: number;
      height: number;
      maxScale: number;
      lines: any[];
      el: HTMLElement;
      svg: HTMLElement;
      pathOuter: HTMLElement;
      pathInner: HTMLElement;
      pathLines: HTMLElement;
    };

    bounding!: {
      left: number;
      top: number;
      width: number;
      height: number;
    };
    letters: Letter[];
    works: any[];
    points: any[];

    tl!: gsap.core.Timeline;
    animationProgress!: number;
    pointsProgress!: number;
    last: {
      animationProgress: number;
      pointsProgress: number;
    };
    scrollProgress: number;
    smoothScrollProgress: number;
    state = 0;
    speed!: number;
    isPaused: boolean;
    isTouchDevice: boolean;
    touchScrollRafId: number;
    touchViewportResizeRafId: number;
    touchViewportRefreshTimeoutId: number;
    touchSectionTop: number;
    touchSectionHeight: number;
    touchLastScrollY: number;
    touchStableFrames: number;
    touchLastViewportWidth: number;
    touchSyncForce: boolean;
    loadIsStarted: boolean;
    reducedMotion: boolean;
    reducedData: boolean;

    constructor() {
      this.el = document.querySelector(".s-work")!;
      this.container = this.el.querySelector(".js-container")!;
      this.ruler = this.el.querySelector(".js-ruler")!;
      this.scene = this.container.querySelector(".js-scene")!;
      this.canvas = this.container.querySelector(".js-canvas")!;
      this.ctx = this.canvas.getContext("2d")!;
      this.title = this.container.querySelector(".js-title")!;
      this.videos = this.container.querySelectorAll("img");

      this.mask = {
        width: 0,
        height: 0,
        maxScale: 1,
        lines: [],
        el: this.el.querySelector(".js-mask")!,
        svg: this.el.querySelector(".js-mask-svg")!,
        pathOuter: this.el.querySelector(".js-mask-path-outer")!,
        pathInner: this.el.querySelector(".js-mask-path-inner")!,
        pathLines: this.el.querySelector(".js-mask-path-lines")!,
      };

      this.letters = [];
      this.title.querySelectorAll(".js-letter").forEach((_letter) => {
        const letter: Letter = {
          el: _letter as HTMLElement,
          ghosts: [],
          freq: 1,
          total: 0,
        };
        this.letters.push(letter);
      });

      this.works = [];
      this.container.querySelectorAll(".js-work").forEach((_work) => {
        const work = {
          el: _work,
        };
        this.works.push(work);
      });

      this.points = [];
      this.scrollProgress = 0;
      this.smoothScrollProgress = 0;
      this.last = {
        animationProgress: 0,
        pointsProgress: 0,
      };

      this.isPaused = true;
      this.isTouchDevice =
        window.matchMedia("(max-width: 768px)").matches ||
        (ScrollTrigger.isTouch === 1 &&
          window.matchMedia("(max-width: 1024px)").matches);
      this.touchScrollRafId = 0;
      this.touchViewportResizeRafId = 0;
      this.touchViewportRefreshTimeoutId = 0;
      this.touchSectionTop = 0;
      this.touchSectionHeight = 0;
      this.touchLastScrollY = -1;
      this.touchStableFrames = 0;
      this.touchLastViewportWidth = window.innerWidth || 0;
      this.touchSyncForce = false;
      this.loadIsStarted = false;
      this.reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      this.reducedData = Boolean((navigator as any).connection?.saveData);

      if (document.readyState === "complete") {
        ticker.nextTick(this.init, this);
      } else {
        emitter.once("siteLoaded", this.init, this);
        // Fallback if siteLoaded is never emitted in standalone
        setTimeout(() => this.init(), 100);
      }
    }

    init() {
      this.setCtxStyle();
      this.setSize();
      this.setMask();
      this.setPoints();
      this.setLetters();
      this.setWorks();
      this.setTimeline();

      this.bindEvents();
    }

    bindEvents() {
      emitter.on("contrastchange", this.setCtxStyle, this);
      emitter.on("resize", this.onResize, this);
      window.addEventListener("resize", () => this.onResize(true)); // Fallback
      window.addEventListener("scroll", this.onTouchScroll, { passive: true });
      document.addEventListener("touchstart", this.onTouchInput, {
        passive: true,
      });
      document.addEventListener("touchmove", this.onTouchInput, {
        passive: true,
      });
      document.addEventListener("touchend", this.onTouchInput, {
        passive: true,
      });
      window.visualViewport?.addEventListener("scroll", this.onTouchScroll, {
        passive: true,
      });
      window.visualViewport?.addEventListener(
        "resize",
        this.onTouchViewportResize,
        { passive: true }
      );

      this.el.addEventListener(
        "intersect",
        this.onIntersect.bind(this) as EventListener,
        {
          passive: true,
        }
      );

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          this.el.dispatchEvent(
            new CustomEvent("intersect", {
              detail: { isIntersecting: entry.isIntersecting },
            })
          );
        });
      });
      observer.observe(this.el);
    }

    lastWidth: number = 0;

    onResize(widthChanged: boolean) {
      if (widthChanged) {
        const width = window.innerWidth;
        if (width === this.lastWidth) return;
        this.lastWidth = width;
        this.touchLastViewportWidth = width;
        this.isTouchDevice =
          window.matchMedia("(max-width: 768px)").matches ||
          (ScrollTrigger.isTouch === 1 &&
            window.matchMedia("(max-width: 1024px)").matches);
        this.reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;
        this.reducedData = Boolean((navigator as any).connection?.saveData);

        this.setCtxStyle();
        this.setSize();
        this.setMask();
        this.setPoints();
        this.setLetters();
        this.setWorks();
        this.setTimeline();

        if (this.isTouchDevice) {
          ScrollTrigger.refresh();
          this.queueTouchSync(true);
        } else {
          this.stopTouchSync();
        }
      }
    }

    onIntersect(e: CustomEvent<{ isIntersecting: boolean }>) {
      this.isPaused = !e.detail.isIntersecting;
      emitter.off("tick", this.tick, this);

      if (this.isTouchDevice) {
        this.queueTouchSync(true);
        return;
      }

      if (!this.isPaused) {
        emitter.on("tick", this.tick, this);
      }
    }

    getCurrentScrollY() {
      const windowScroll =
        window.scrollY ||
        window.pageYOffset ||
        document.documentElement.scrollTop ||
        document.body.scrollTop ||
        0;

      if (Number.isFinite(windowScroll)) {
        return windowScroll;
      }

      const visualViewportScroll = window.visualViewport?.pageTop;
      return typeof visualViewportScroll === "number" &&
        Number.isFinite(visualViewportScroll)
        ? visualViewportScroll
        : 0;
    }

    getViewportHeight() {
      const visualViewportHeight = window.visualViewport?.height;
      if (
        typeof visualViewportHeight === "number" &&
        Number.isFinite(visualViewportHeight)
      ) {
        return visualViewportHeight;
      }

      return window.innerHeight || this.bounding.height || 1;
    }

    measureTouchRange() {
      const scrollY = this.getCurrentScrollY();
      const rect = this.el.getBoundingClientRect();
      this.touchSectionTop = rect.top + scrollY;
      this.touchSectionHeight = this.el.offsetHeight;
    }

    isTouchSectionActive() {
      const rect = this.el.getBoundingClientRect();
      const viewportHeight = this.getViewportHeight();
      return rect.bottom >= -viewportHeight && rect.top <= viewportHeight * 2;
    }

    getTouchTimelineProgress(scrollY = this.getCurrentScrollY()) {
      const totalScrollableDistance = Math.max(
        this.touchSectionHeight - this.getViewportHeight(),
        1
      );

      return Math.max(
        0,
        Math.min(1, (scrollY - this.touchSectionTop) / totalScrollableDistance)
      );
    }

    getTouchScrollEffectProgress(scrollY = this.getCurrentScrollY()) {
      const viewportHeight = this.getViewportHeight();
      const top = this.touchSectionTop - scrollY;
      const bottom = top + this.touchSectionHeight;
      const topProgress = Math.max(Math.min(top / viewportHeight, 1), 0);
      const bottomProgress = Math.max(Math.min(bottom / viewportHeight, 1), 0);

      return -topProgress + (1 - bottomProgress);
    }

    onTouchScroll = () => {
      if (!this.isTouchDevice || !this.tl) return;
      this.queueTouchSync();
    };

    onTouchInput = () => {
      if (!this.isTouchDevice || !this.tl) return;
      this.queueTouchSync(true);
    };

    onTouchViewportResize = () => {
      if (!this.isTouchDevice || !this.tl) return;
      if (this.touchViewportResizeRafId) return;

      this.touchViewportResizeRafId = requestAnimationFrame(() => {
        this.touchViewportResizeRafId = 0;

        const width = window.innerWidth || document.documentElement.clientWidth;
        const widthChanged = Math.abs(width - this.touchLastViewportWidth) > 1;
        this.touchLastViewportWidth = width;

        if (widthChanged) {
          this.onResize(true);
          return;
        }

        this.measureTouchRange();
        this.updateTouchTimeline(true);
        this.queueTouchSync(true);

        clearTimeout(this.touchViewportRefreshTimeoutId);
        this.touchViewportRefreshTimeoutId = window.setTimeout(() => {
          if (!this.isTouchDevice || !this.tl) return;
          this.measureTouchRange();
          ScrollTrigger.refresh();
          this.updateTouchTimeline(true);
        }, 180);
      });
    };

    queueTouchSync(force = false) {
      if (force) {
        this.touchSyncForce = true;
      }
      if (this.touchScrollRafId) return;

      const sync = () => {
        if (!this.isTouchDevice || !this.tl) {
          this.touchScrollRafId = 0;
          return;
        }

        const scrollY = this.getCurrentScrollY();
        const scrollChanged = Math.abs(scrollY - this.touchLastScrollY) > 0.01;
        const isActive = this.isTouchSectionActive();
        const shouldForce = this.touchSyncForce || force;
        this.touchSyncForce = false;

        this.touchLastScrollY = scrollY;
        this.touchStableFrames = scrollChanged ? 0 : this.touchStableFrames + 1;

        if (isActive) {
          this.updateTouchTimeline(shouldForce || scrollChanged, scrollY);
        }

        if (scrollChanged || this.touchStableFrames < 8) {
          this.touchScrollRafId = requestAnimationFrame(sync);
          return;
        }

        this.touchScrollRafId = 0;
      };

      this.touchScrollRafId = requestAnimationFrame(sync);
    }

    stopTouchSync() {
      if (this.touchScrollRafId) {
        cancelAnimationFrame(this.touchScrollRafId);
        this.touchScrollRafId = 0;
      }
      if (this.touchViewportResizeRafId) {
        cancelAnimationFrame(this.touchViewportResizeRafId);
        this.touchViewportResizeRafId = 0;
      }
      if (this.touchViewportRefreshTimeoutId) {
        clearTimeout(this.touchViewportRefreshTimeoutId);
        this.touchViewportRefreshTimeoutId = 0;
      }
      this.touchSyncForce = false;
    }

    updateTouchTimeline(force = false, scrollY = this.getCurrentScrollY()) {
      if (
        !this.isTouchDevice ||
        !this.tl ||
        this.reducedMotion ||
        this.reducedData
      ) {
        return;
      }

      const nextProgress = this.getTouchTimelineProgress(scrollY);

      if (force || Math.abs(nextProgress - this.tl.progress()) > 0.0005) {
        this.tl.progress(nextProgress, false);
      }

      this.syncScrollEffects(force, scrollY);
    }

    setCtxStyle() {
      const color = getComputedStyle(this.el).getPropertyValue(
        "--color-primary"
      );
      ticker.nextTick(() => {
        this.ctx.strokeStyle = color;
      }, this);
    }

    setSize() {
      const sectionHeightPerWork = this.isTouchDevice ? 45 : 50;
      this.el.style.setProperty(
        "--height",
        this.works.length * sectionHeightPerWork + "svh"
      );
      const bounding = this.container.getBoundingClientRect();
      // Fallback for window.safeWidth/Height
      const safeWidth = window.safeWidth || window.innerWidth;
      const safeHeight = window.safeHeight || window.innerHeight;

      this.bounding = {
        left: bounding.left,
        top: bounding.top,
        width: safeWidth,
        height: safeHeight,
      };

      this.canvas.width = this.bounding.width;
      this.canvas.height = this.bounding.height;
      this.speed = Math.hypot(this.bounding.width, this.bounding.height) * 4;

      if (this.isTouchDevice) {
        this.measureTouchRange();
      }
    }

    setMask() {
      const { mask } = this;
      const width = mask.el.clientWidth;
      const height = mask.el.clientHeight;

      mask.width = width;
      mask.height = height;
      mask.svg.style.width = mask.width + "px";
      mask.svg.style.height = mask.height + "px";

      const elBounding = this.el.getBoundingClientRect();
      const rulerBounding = this.ruler.getBoundingClientRect();
      const rulerWidth = rulerBounding.width;
      const rulerHeight = rulerBounding.height;
      const offsetX = rulerBounding.left - elBounding.left;
      const offsetY = rulerBounding.top - elBounding.top;

      const dOuter = `M -1 0 L ${width + 2} 0 L ${width + 2} ${height} L -1 ${height} Z`;

      const corners = {
        tl: { x: offsetX, y: offsetY },
        tr: { x: offsetX + rulerWidth, y: offsetY },
        br: { x: offsetX + rulerWidth, y: offsetY + rulerHeight },
        bl: { x: offsetX, y: offsetY + rulerHeight },
      };

      let size = (corners.tr.x - corners.tl.x) / 2;
      const safeWidth = window.safeWidth || window.innerWidth;
      const safeHeight = window.safeHeight || window.innerHeight || height;
      const expandMargin = safeWidth > 767 ? 96 : 40;
      const horizontalScale =
        (safeWidth + rulerWidth + expandMargin * 2) /
        Math.max(rulerWidth, 1);
      const verticalScale =
        (safeHeight + rulerHeight + expandMargin * 2) /
        Math.max(rulerHeight, 1);
      mask.maxScale = Math.max(horizontalScale, verticalScale) * 1.15;

      let dInner = `M ${corners.tl.x} ${corners.tl.y + size} A ${size} ${size} 0 0 1 ${corners.tr.x} ${corners.tr.y + size} L ${corners.br.x} ${corners.br.y - size} A ${size} ${size} 0 0 1 ${corners.bl.x} ${corners.bl.y - size} Z`;
      const linesClip = `${dOuter} ${dInner}`;

      mask.pathOuter.setAttribute("d", `${dOuter} ${dInner}`);

      const thickness = safeWidth > 767 ? 16 : 8;
      corners.tl.x += thickness;
      corners.tl.y += thickness;
      corners.tr.x -= thickness;
      corners.tr.y += thickness;
      corners.br.x -= thickness;
      corners.br.y -= thickness;
      corners.bl.x += thickness;
      corners.bl.y -= thickness;

      size = (corners.tr.x - corners.tl.x) / 2;
      dInner = `M ${corners.tl.x} ${corners.tl.y + size} A ${size} ${size} 0 0 1 ${corners.tr.x} ${corners.tr.y + size} L ${corners.br.x} ${corners.br.y - size} A ${size} ${size} 0 0 1 ${corners.bl.x} ${corners.bl.y - size} Z`;

      mask.pathInner.setAttribute("d", `${dOuter} ${dInner}`);

      mask.lines = [];
      const vLines = safeWidth > 767 ? 12 : 8;
      const gapX = width / vLines;
      const gapY = height * 0.1;
      const hLines = Math.ceil(height / gapY);

      for (let i = 1; i < vLines; i++) {
        const x = gapX * i;
        mask.lines.push({ p1: { x, y: 0 }, p2: { x, y: height } });
      }

      for (let i = 0; i < hLines; i++) {
        const y = gapY * i;
        mask.lines.push({ p1: { x: 0, y }, p2: { x: width, y } });
      }

      let dLines = "";
      mask.lines.forEach((line) => {
        dLines += `M ${line.p1.x} ${line.p1.y} L ${line.p2.x} ${line.p2.y} `;
      });

      mask.pathLines.setAttribute("d", dLines);
      mask.pathLines.style.clipPath = `path(evenodd, '${linesClip}')`;
    }

    setLetters() {
      const { letters, scene } = this;
      const safeWidth = window.safeWidth || window.innerWidth;
      const reduceMotion = this.reducedMotion || this.reducedData;

      letters.forEach((letter, j) => {
        letter.ghosts.forEach((ghost: Ghost) => {
          ghost.el.remove();
        });
        letter.ghosts = [];

        const bounding = letter.el.getBoundingClientRect();
        letter.width = bounding.width;
        letter.height = bounding.height;
        letter.top = bounding.top - this.bounding.top;
        letter.left = bounding.left;
        letter.freq = 1 + Math.random();

        const multiplier = safeWidth > 767 ? 1.6 : 0.75;

        if (reduceMotion) {
          letter.total = 0;
        } else {
          letter.total =
            Math.round((this.bounding.width / letter.width) * multiplier) + 2;
          if (safeWidth < 768) {
            letter.total = Math.max(3, Math.min(letter.total, 10));
          }
        }

        for (let i = 0; i < letter.total; i++) {
          const el = document.createElement("span");
          el.classList.add("s__scene__letter");
          el.classList.add("js-letter");
          el.innerText = letter.el.innerText;
          el.dataset.letter = letter.el.innerText;
          scene.appendChild(el);

          const ghost = {
            el,
            x: letter.left,
            y: letter.top,
            z: Math.random() * 100,
            i: i - letter.total * 0.5,
            p: (i / letter.total - 0.5) * 2,
            ap: Math.abs(i / letter.total - 0.5) * 2,
            mx: 0,
            my: 0,
          };

          el.style.top = ghost.y + "px";
          el.style.left = ghost.x + "px";
          el.style.zIndex = String(
            j !== 1 && j !== 2 && (j + letters.length + i) % 5 === 0 ? 3 : 1
          );
          el.style.setProperty("--ix", String(ghost.i));
          el.style.setProperty(
            "--iy",
            String(((j + 1) / (letters.length + 1) - 0.5) * 2)
          );
          el.style.setProperty("--ap", String(ghost.ap));
          el.style.setProperty("--p", String(ghost.p));

          letter.ghosts.push(ghost);
        }
      });
    }

    setWorks() {
      const { works } = this;
      works.forEach((work, i) => {
        const el = work.el;
        // Increase minimum size and range (0.8 to 1.2 instead of 0.5 to 1.0)
        el.style.setProperty("--size", String(0.8 + Math.random() * 0.4));
        el.style.setProperty(
          "--y",
          String((0.5 + Math.random() * 0.5) * (i % 2 ? -1 : 1))
        );
      });
    }

    setTimeline() {
      const { el, container, works, scene, mask } = this;
      const worksEl = works.map((work) => work.el);
      let { tl } = this;
      if (tl) {
        tl.scrollTrigger?.kill();
        tl.kill();
      }

      const introDuration = 10.0;
      const cardsDelay = 0.35;
      const cardsStart = introDuration + cardsDelay;

      const timelineConfig: gsap.TimelineVars = {
        paused: this.isTouchDevice || this.reducedMotion || this.reducedData,
        onUpdate: () => {
          scene.style.setProperty("--state", String(this.state));
        },
      };

      if (!this.isTouchDevice && !this.reducedMotion && !this.reducedData) {
        timelineConfig.scrollTrigger = {
          trigger: el,
          start: "top top",
          end: "bottom bottom",
          scrub: 1,
          invalidateOnRefresh: true,
          fastScrollEnd: false,
          onUpdate: () => {
            this.syncScrollEffects(false);
          },
        };
      }

      tl = gsap.timeline(timelineConfig);
      this.tl = tl;

      const isMobile = window.matchMedia(
        "(max-width: 768px)"
      ).matches;

      tl.fromTo(
        scene,
        { scale: 0.75 },
        { scale: 1, duration: introDuration, ease: "power3.in" },
        0
      );

      tl.fromTo(
        mask.el,
        { scale: 1 },
        { scale: mask.maxScale, duration: introDuration, ease: "power4.in" },
        0
      );

      if (!isMobile) {
        tl.fromTo(
          container,
          { clipPath: "inset(0 1rem)" },
          {
            clipPath: "inset(0 0rem)",
            duration: introDuration,
            ease: "power3.in",
          },
          0
        );
      }

      tl.fromTo(
        this,
        { pointsProgress: 0 },
        { pointsProgress: 1, duration: 1, ease: "power4.inOut" },
        introDuration
      );
      tl.fromTo(
        this,
        { state: 0 },
        { state: 1, duration: 0.75, ease: "power4.in" },
        introDuration
      );
      const cardsDuration = 0.9;
      const cardsStagger = 0.32;
      tl.fromTo(
        worksEl,
        { attr: { progress: 1 } },
        {
          attr: { progress: -1 },
          duration: cardsDuration,
          ease: "slow(0.15, 0.6)",
          stagger: cardsStagger,
        },
        cardsStart
      );
      tl.fromTo(
        this,
        { animationProgress: 0 },
        {
          animationProgress: 10000,
          duration: tl.totalDuration(),
          ease: "power1.out",
        },
        cardsStart
      );
      tl.fromTo(
        this,
        { state: 1 },
        {
          state: 0,
          duration: 0.75,
          ease: "power4.inOut",
          immediateRender: false,
        },
        "-=1"
      );
      tl.fromTo(
        mask.el,
        { scale: mask.maxScale },
        {
          scale: 1,
          duration: 0.75,
          ease: "power4.inOut",
          immediateRender: false,
        },
        "-=1"
      );
      tl.fromTo(
        scene,
        { scale: 1 },
        {
          scale: 0.75,
          duration: 0.75,
          ease: "power3.inOut",
          immediateRender: false,
        },
        "-=1"
      );

      if (!isMobile) {
        tl.fromTo(
          container,
          { clipPath: "inset(0 0rem)" },
          {
            clipPath: "inset(0 1rem)",
            duration: 0.75,
            ease: "power3.inOut",
            immediateRender: false,
          },
          "-=1"
        );
      }

      tl.fromTo(
        this,
        { pointsProgress: 1 },
        { pointsProgress: 0, duration: 1, ease: "power4.inOut" },
        "-=1"
      );

      if (this.isTouchDevice) {
        this.measureTouchRange();
        this.updateTouchTimeline(true);
        this.queueTouchSync(true);
      }

      if (this.reducedMotion || this.reducedData) {
        tl.progress(1);
        this.syncScrollEffects(true);
      }
    }

    moveLetters() {
      if (this.reducedMotion || this.reducedData) return;
      const { speed, letters, animationProgress } = this;
      letters.forEach((letter, i) => {
        const letterSpeed = speed * letter.freq;
        letter.ghosts.forEach((ghost: Ghost, index: number) => {
          let progress =
            (((animationProgress % letterSpeed) / letterSpeed +
              index / letter.total) %
              1) /
              0.7 -
            0.15;
          ghost.el.style.setProperty("--progress", String(progress));
        });
      });
    }

    setPoints() {
      const { bounding } = this;
      this.points = [];

      // Mobile Optimization: Disable canvas points
      const isMobile = window.matchMedia(
        "(max-width: 768px)"
      ).matches;
      if (isMobile || this.reducedMotion || this.reducedData) return;

      const gap = 24;
      const cols = Math.ceil((bounding.width * 1.2) / gap);
      const rows = Math.ceil((bounding.height * 1.2) / gap);
      const offsetX = (bounding.width - cols * gap) * 0.5;
      const offsetY = (bounding.height - rows * gap) * 0.5;
      const hWidth = bounding.width * 0.5;
      const hHeight = bounding.height * 0.5;

      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          const x = i * gap + offsetX;
          const y = j * gap + offsetY;
          const dx = hWidth - x;
          const dy = hHeight - y;
          this.points.push({ x, y, dx, dy, m: Math.random(), flowX: 0 });
        }
      }
    }

    movePoints() {
      const { points, animationProgress } = this;
      points.forEach((p) => {
        p.flowX = (animationProgress * -0.05) % 24;
      });
    }

    drawPoints() {
      const { bounding, ctx, points, animationProgress, pointsProgress, last } =
        this;
      const rAnimationProgress = Math.round(animationProgress * 100) / 100;
      const rPointsProgress = Math.round(pointsProgress * 100) / 100;

      if (
        rPointsProgress === last.pointsProgress &&
        rAnimationProgress === last.animationProgress
      )
        return;

      ctx.clearRect(0, 0, bounding.width, bounding.height);
      ctx.beginPath();
      points.forEach((point) => {
        const x = point.x + point.dx * (1 - pointsProgress) * 0.2 + point.flowX;
        const y = point.y + point.dy * (1 - pointsProgress) * 0.2;
        ctx.rect(x, y, 0.5, 0.5);
      });
      ctx.stroke();
      last.pointsProgress = rPointsProgress;
      last.animationProgress = rAnimationProgress;
    }

    syncScrollEffects(force = false, touchScrollY?: number) {
      const nextScrollProgress = this.isTouchDevice
        ? this.getTouchScrollEffectProgress(touchScrollY)
        : (() => {
            const viewportHeight = window.innerHeight || this.bounding.height || 1;
            const rect = this.el.getBoundingClientRect();
            const topProgress = Math.max(
              Math.min(rect.top / viewportHeight, 1),
              0
            );
            const bottomProgress = Math.max(
              Math.min(rect.bottom / viewportHeight, 1),
              0
            );

            return -topProgress + (1 - bottomProgress);
          })();

      if (
        force ||
        Math.abs(nextScrollProgress - this.scrollProgress) > 0.001
      ) {
        this.scrollProgress = nextScrollProgress;
        this.smoothScrollProgress +=
          (this.scrollProgress - this.smoothScrollProgress) * 0.1;
        this.el.style.setProperty(
          "--scroll-progress",
          String(this.scrollProgress)
        );
      }

      this.moveLetters();
    }

    tick() {
      this.syncScrollEffects();

      // Movement
      // handled in syncScrollEffects

      // Draw
      if (window.innerWidth >= 768) {
        // this.drawPoints()
      }
    }
  }

  const sectionRoot = document.querySelector(".s-work");
  if (sectionRoot) {
    const initSection = () => {
      if ((sectionRoot as HTMLElement).dataset.sWorkInit) return;
      (sectionRoot as HTMLElement).dataset.sWorkInit = "true";
      new Section();
    };

    if ("IntersectionObserver" in window) {
      const initObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              initSection();
              observer.disconnect();
            }
          });
        },
        { rootMargin: "200px 0px", threshold: 0.01 }
      );
      initObserver.observe(sectionRoot);
    } else {
      initSection();
    }
  }
</script>

