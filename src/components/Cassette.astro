---
export interface Props {
  overlaySrc?: string;
  color: string;
  offsetXPercent?: number;
  offsetYPercent?: number;
  alt?: string;
  overlaySizePercent?: number;
  overlaySizeAxis?: "fit" | "width" | "height";
}
const {
  color,
  overlaySrc,
  overlaySizePercent = 100,
  overlaySizeAxis = "fit",
  offsetXPercent = 0,
  offsetYPercent = 0,
  alt = "",
} = Astro.props;

const ox = `${offsetXPercent}%`;
const oy = `${offsetYPercent}%`;

const sizeStyle = (() => {
  if (overlaySizeAxis === "width") {
    return `width: ${overlaySizePercent}%; height: auto;`;
  }
  if (overlaySizeAxis === "height") {
    return `height: ${overlaySizePercent}%; width: auto;`;
  }
  // fit (default): keep aspect ratio and fit inside container
  return "width: auto; height: auto; max-width: 100%; max-height: 100%;";
})();

const idSuffix = Math.random().toString(36).substr(2, 9);
