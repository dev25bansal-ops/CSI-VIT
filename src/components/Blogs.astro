---
import BlogsCard from "./BlogsCard.astro";
import { reader } from "../utils/reader";
import { getAssetUrl } from "../utils/cdn";

const blogsData = await reader.singletons.blogs.read();
const blogData = blogsData?.items ?? [];

const fallbackCover = "/blogs/placeholder.webp";
const HASHNODE_HOST = "blog.csivitchennai.in";
const HASHNODE_ENDPOINT = "https://gql.hashnode.com";

async function fetchHashnodeCover(url: string): Promise<string | null> {
  try {
    const parsed = new URL(url);
    const slug = parsed.pathname.replace(/^\/|\/$/g, "");
    if (!slug) return null;

    const query = `
      query PostBySlug($host: String!, $slug: String!) {
        publication(host: $host) {
          post(slug: $slug) {
            coverImage {
              url
            }
          }
        }
      }
    `;

    const response = await fetch(HASHNODE_ENDPOINT, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "User-Agent": "Mozilla/5.0 (compatible; AstroBot/1.0)",
      },
      body: JSON.stringify({
        query,
        variables: { host: HASHNODE_HOST, slug },
      }),
    });

    if (!response.ok) return null;
    const payload = await response.json();
    const post = payload?.data?.publication?.post;
    if (!post) return null;

    if (typeof post.coverImage === "string") return post.coverImage;
    if (post.coverImage && typeof post.coverImage.url === "string") {
      return post.coverImage.url;
    }
  } catch (error) {
    console.warn(`Failed to fetch Hashnode cover for ${url}:`, error);
  }

  return null;
}

const blogsWithImages = await Promise.all(
  blogData.map(async (blog) => {
    if (blog.cover) {
      return { link: blog.link, bgurl: blog.cover };
    }

    const hashnodeCover = await fetchHashnodeCover(blog.link);
    return { link: blog.link, bgurl: hashnodeCover || fallbackCover };
  })
);
---

<div
  class="flex flex-col space-y-12 md:space-y-16 items-center justify-start pt-16 md:pt-20 w-full min-h-screen"
>
  <div
    class="blogs-title-bar bg-[#F95F4A] w-11/12 rounded-full h-[10vh] md:h-[15vh] lg:h-[20vh] grid grid-cols-[1fr_auto_1fr] items-center px-2 md:px-8 text-stone-900 border border-[#fefcd9]"
  >
    <div
      id="rotate-svg"
      data-type="Filled"
      class="w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 relative justify-self-start"
    >
      <img
        src={getAssetUrl("/rotate.webp")}
        class="rotate-svg w-full h-full block"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="flex items-center justify-center h-full">
      <span
        class="blogs-title font-normal font-['PolySans_Trial'] text-4xl sm:text-6xl md:text-8xl lg:text-[150px] leading-none text-center transform translate-y-[5%]"
      >
        BLOGS
      </span>
    </div>

    <div
      data-type="Filled"
      class="w-12 h-12 md:w-20 md:h-20 lg:w-24 lg:h-24 relative justify-self-end"
    >
      <img
        src={getAssetUrl("/rotate.webp")}
        class="rotate-svg w-full h-full block"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>

  <div class="w-11/12 md:w-5/6 lg:w-2/3 max-w-6xl justify-start">
    <span
      class="text-[#F95F4A] font-light font-['PolySans_Trial'] uppercase text-base leading-relaxed max-w-4xl max-[640px]:text-[0.95rem] max-[640px]:leading-[1.45] max-[640px]:max-w-[28rem] max-[480px]:text-[0.85rem] max-[480px]:leading-[1.4]"
    >
      Our blogs take you behind the scenes of the technologies shaping the world
      today.
    </span>
    <span
      class="text-white font-light font-['PolySans_Trial'] uppercase text-base leading-relaxed max-w-4xl max-[640px]:text-[0.95rem] max-[640px]:leading-[1.45] max-[640px]:max-w-[28rem] max-[480px]:text-[0.85rem] max-[480px]:leading-[1.4]"
    >
      Whether it’s LLMs, UI/UX, microchips, or Web3, we break it down so anyone
      can follow. Find your next read just below.
    </span>
  </div>

  <!-- Carousel Container -->
  <div class="w-full flex flex-col items-center space-y-8 relative">
    <!-- Slider Wrapper -->
    <div
      class="relative w-full max-w-[88vw] sm:max-w-[90%] md:max-w-[85%] lg:max-w-[80%] flex items-center justify-center"
    >
      <!-- Left Arrow -->
      <button
        id="prev-btn"
        class="absolute left-[-2rem] md:left-[-4rem] z-10 text-[#F95F4A] hover:text-white transition-colors duration-300"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-8 h-8 md:w-12 md:h-12"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15.75 19.5L8.25 12l7.5-7.5"></path>
        </svg>
      </button>

      <!-- Slider Window -->
      <div class="slider-window overflow-hidden w-full">
        <div id="blogs-track" class="flex flex-row items-center">
          {
            blogsWithImages.map((blog) => (
              <div class="blog-card-wrapper flex-shrink-0 w-full sm:w-auto px-3 sm:px-4">
                <BlogsCard {...blog} />
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right Arrow -->
      <button
        id="next-btn"
        class="absolute right-[-2rem] md:right-[-4rem] z-10 text-[#F95F4A] hover:text-white transition-colors duration-300"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-8 h-8 md:w-12 md:h-12"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M8.25 4.5l7.5 7.5-7.5 7.5"></path>
        </svg>
      </button>
    </div>

    <!-- Dots -->
    <div id="dots-container" class="flex space-x-2 mt-4">
      <!-- Dots will be injected here -->
    </div>
  </div>

  <div class="flex justify-center w-full mt-8">
    <a
      href="https://blog.csivitchennai.in"
      target="_blank"
      rel="noopener noreferrer"
      class="w-[80%] sm:w-full max-w-sm md:max-w-md lg:max-w-lg xl:max-w-xl px-5 py-2 sm:px-8 sm:py-4 rounded-[41px] border border-[#F95F4A] text-center hover:bg-[#F95F4A] hover:text-white transition-all duration-300 cursor-pointer group block"
    >
      <div
        class="text-white group-hover:text-white text-sm sm:text-base font-light font-['PolySans_Trial'] uppercase tracking-wide"
      >
        <span class="block md:hidden">Still Curious? Dive Deeper</span>
        <span class="hidden md:block"
          >Still Curious? Dive Deeper into Our Brainwaves</span
        >
      </div>
    </a>
  </div>
</div>

<style>
  @media (max-height: 700px) {
    .blogs-title-bar {
      height: clamp(72px, 24vh, 160px);
    }

    .blogs-title {
      font-size: clamp(2rem, 16vh, 6rem);
      line-height: 0.9;
    }
  }

  @media (max-height: 400px) {
    .blogs-title-bar {
      height: clamp(56px, 28vh, 120px);
    }

    .blogs-title {
      font-size: clamp(1.6rem, 14vh, 4rem);
    }
  }
  @media (max-width: 450px) {
    .blogs-title-bar {
      height: clamp(56px, 28vh, 120px);
    }

    .blogs-title {
      font-size: clamp(1.8rem, 14vh, 4rem);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  gsap.to(".rotate-svg", {
    rotation: 360,
    repeat: -1,
    duration: 5,
    ease: "linear",
  });

  const track = document.getElementById("blogs-track");
  const cards = document.querySelectorAll(".blog-card-wrapper");
  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");
  const dotsContainer = document.getElementById("dots-container");
  const sliderWindow = document.querySelector(
    ".slider-window"
  ) as HTMLElement | null;

  let currentIndex = 0;
  let itemsPerPage = 3;
  let cardWidth = 0;
  let totalPages = 0;
  let isDragging = false;
  let startX = 0;
  let startY = 0;
  let dragDelta = 0;
  let activePointerId: number | null = null;

  function updateDimensions() {
    const width = window.innerWidth;
    if (width < 640) itemsPerPage = 1;
    else if (width < 1024) itemsPerPage = 2;
    else itemsPerPage = 3;

    // Calculate card width based on the first card's width + padding
    // We assume all cards are same size.
    // The wrapper has padding, so offsetWidth includes it.
    if (cards.length > 0) {
      cardWidth = (cards[0] as HTMLElement).offsetWidth;
    }

    totalPages = Math.ceil(cards.length / itemsPerPage);
    // Ensure index is within bounds after resize
    if (currentIndex >= totalPages) currentIndex = totalPages - 1;
    if (currentIndex < 0) currentIndex = 0;

    updateSliderPosition(false); // No animation on resize
    updateDots();
  }

  function updateSliderPosition(animate = true) {
    if (!track) return;

    // Calculate the translation value
    // We slide by 'itemsPerPage' number of cards, or whatever is left
    // Actually, a simpler way for a smooth slider is to slide by 'itemsPerPage * cardWidth'
    // But since we want pages, we slide to the start of the current page.

    const xValue = -(currentIndex * itemsPerPage * cardWidth);

    // Check if we are at the end and don't have enough items to fill the page
    // In that case, we might want to clamp, but for now let's just slide.

    if (animate) {
      gsap.to(track, {
        x: xValue,
        duration: 0.5,
        ease: "power2.out",
      });
    } else {
      gsap.set(track, { x: xValue });
    }
  }

  function isMobileView() {
    return window.matchMedia("(max-width: 768px)").matches;
  }

  function handlePointerDown(event: Event) {
    const pointerEvent = event as PointerEvent;
    if (!sliderWindow || !track || !isMobileView()) return;
    if (pointerEvent.pointerType === "mouse" && pointerEvent.button !== 0)
      return;

    isDragging = true;
    dragDelta = 0;
    startX = pointerEvent.clientX;
    startY = pointerEvent.clientY;
    activePointerId = pointerEvent.pointerId;
    sliderWindow.setPointerCapture(pointerEvent.pointerId);
    sliderWindow.classList.add("is-dragging");
  }

  function handlePointerMove(event: Event) {
    const pointerEvent = event as PointerEvent;
    if (!sliderWindow || !track || !isDragging) return;
    if (activePointerId !== null && pointerEvent.pointerId !== activePointerId)
      return;

    const deltaX = pointerEvent.clientX - startX;
    const deltaY = pointerEvent.clientY - startY;

    if (Math.abs(deltaY) > Math.abs(deltaX) && Math.abs(deltaY) > 12) {
      return;
    }

    dragDelta = deltaX;
    const baseX = -(currentIndex * itemsPerPage * cardWidth);
    gsap.set(track, { x: baseX + dragDelta });
  }

  function handlePointerUp(event: Event) {
    const pointerEvent = event as PointerEvent;
    if (!sliderWindow || !track || !isDragging) return;
    if (activePointerId !== null && pointerEvent.pointerId !== activePointerId)
      return;

    isDragging = false;
    sliderWindow.classList.remove("is-dragging");
    sliderWindow.releasePointerCapture(pointerEvent.pointerId);
    activePointerId = null;

    const threshold = Math.min(90, cardWidth * 0.2);

    if (Math.abs(dragDelta) > threshold) {
      if (dragDelta < 0) {
        currentIndex = Math.min(currentIndex + 1, totalPages - 1);
      } else {
        currentIndex = Math.max(currentIndex - 1, 0);
      }
    }

    updateSliderPosition();
    updateDots();
  }

  if (sliderWindow) {
    sliderWindow.addEventListener(
      "pointerdown",
      handlePointerDown as EventListener
    );
    sliderWindow.addEventListener(
      "pointermove",
      handlePointerMove as EventListener
    );
    sliderWindow.addEventListener(
      "pointerup",
      handlePointerUp as EventListener
    );
    sliderWindow.addEventListener(
      "pointercancel",
      handlePointerUp as EventListener
    );
    sliderWindow.addEventListener(
      "pointerleave",
      handlePointerUp as EventListener
    );
  }

  function updateDots() {
    if (!dotsContainer) return;
    dotsContainer.innerHTML = "";
    for (let i = 0; i < totalPages; i++) {
      const dot = document.createElement("div");
      dot.classList.add(
        "w-3",
        "h-3",
        "rounded-full",
        "cursor-pointer",
        "transition-colors",
        "duration-300"
      );
      if (i === currentIndex) {
        dot.classList.add("bg-[#F95F4A]");
      } else {
        dot.classList.add("bg-gray-500", "hover:bg-[#F95F4A]");
      }
      dot.addEventListener("click", () => {
        currentIndex = i;
        updateSliderPosition();
        updateDots();
      });
      dotsContainer.appendChild(dot);
    }
  }

  if (prevBtn) {
    prevBtn.addEventListener("click", () => {
      if (currentIndex > 0) {
        currentIndex--;
      } else {
        currentIndex = totalPages - 1; // Loop to end
      }
      updateSliderPosition();
      updateDots();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener("click", () => {
      if (currentIndex < totalPages - 1) {
        currentIndex++;
      } else {
        currentIndex = 0; // Loop to start
      }
      updateSliderPosition();
      updateDots();
    });
  }

  // Initialize and handle resize
  window.addEventListener("resize", updateDimensions);

  // Wait for layout to be stable
  // Using requestAnimationFrame or setTimeout to ensure DOM is rendered
  setTimeout(() => {
    updateDimensions();
  }, 100);
</script>

<style>
  .slider-window {
    touch-action: pan-y;
  }

  .slider-window.is-dragging a {
    pointer-events: none;
  }
</style>
