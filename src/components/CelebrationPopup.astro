---
import { getAssetUrl } from "../utils/cdn";
---

<div
  id="celebration-popup"
  class="celebration-popup"
  role="dialog"
  aria-modal="true"
  aria-labelledby="celebration-popup-title"
  aria-describedby="celebration-popup-message"
  hidden
>
  <div class="celebration-popup__backdrop" data-popup-close></div>
  <div class="celebration-popup__panel">
    <button
      type="button"
      class="celebration-popup__close"
      data-popup-close
      aria-label="Close celebration popup"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18"></path>
      </svg>
    </button>

    <div class="celebration-popup__content">
      <img
        src={getAssetUrl("/acm-celeb.png")}
        alt="CSI-VIT celebrating the chapter award"
        class="celebration-popup__image"
        loading="eager"
        decoding="async"
      />

      <div class="celebration-popup__text">
        <h2 id="celebration-popup-title" class="celebration-popup__title">
          CSI International Chapter Award for Outstanding School Service
        </h2>
        <p id="celebration-popup-message" class="celebration-popup__message">
          Happy to annouce that CSI-VIT has been awarded the CSI International
          Chapter Award for Outstanding School Service!
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const OPEN_DELAY_MS = 450;

    const initCelebrationPopup = () => {
      const popup = document.getElementById("celebration-popup");
      if (!popup) return;

      const closeTargets = popup.querySelectorAll("[data-popup-close]");
      const openPopup = () => {
        popup.hidden = false;
        requestAnimationFrame(() => {
          popup.dataset.state = "open";
        });
        document.body.style.overflow = "hidden";
      };

      const closePopup = () => {
        popup.dataset.state = "closed";
        document.body.style.overflow = "";
        window.setTimeout(() => {
          popup.hidden = true;
        }, 260);
      };

      closeTargets.forEach((target) => {
        target.addEventListener("click", closePopup);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && popup.dataset.state === "open") {
          closePopup();
        }
      });

      const scheduleOpen = () => {
        window.setTimeout(openPopup, OPEN_DELAY_MS);
      };

      if (sessionStorage.getItem("preloaderShown")) {
        scheduleOpen();
        return;
      }

      window.addEventListener("preloader:done", scheduleOpen, { once: true });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initCelebrationPopup, {
        once: true,
      });
    } else {
      initCelebrationPopup();
    }
  })();
</script>

<style>
  .celebration-popup {
    position: fixed;
    inset: 0;
    z-index: 10001;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.26s ease;
  }

  .celebration-popup[data-state="open"] {
    opacity: 1;
  }

  .celebration-popup__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(13, 14, 13, 0.72);
    backdrop-filter: blur(6px);
  }

  .celebration-popup__panel {
    position: relative;
    width: min(100%, 900px);
    background: transparent;
    overflow: visible;
    transform: translateY(24px) scale(0.98);
    transition: transform 0.3s ease;
  }

  .celebration-popup[data-state="open"] .celebration-popup__panel {
    transform: translateY(0) scale(1);
  }

  .celebration-popup__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    background: rgba(13, 14, 13, 0.48);
    color: rgba(255, 255, 255, 0.82);
    transition:
      border-color 0.2s ease,
      color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .celebration-popup__close:hover {
    border-color: rgba(249, 95, 74, 0.6);
    background: rgba(249, 95, 74, 0.08);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .celebration-popup__close svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .celebration-popup__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .celebration-popup__image {
    width: min(100%, 760px);
    max-height: min(68vh, 780px);
    height: auto;
    object-fit: contain;
    object-position: center;
    filter: drop-shadow(0 22px 60px rgba(0, 0, 0, 0.45));
  }

  .celebration-popup__text {
    position: relative;
    z-index: 1;
    width: min(100%, 680px);
    padding: 0;
    text-align: center;
  }

  .celebration-popup__title {
    margin: 0;
    color: #ffffff;
    font-family:
      "PolySans Trial", Inter, sans-serif;
    font-size: clamp(1.3rem, 2.6vw, 1.85rem);
    line-height: 1.12;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .celebration-popup__message {
    margin: 0.9rem 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1rem;
    line-height: 1.62;
    text-wrap: balance;
  }

  @media (max-width: 768px) {
    .celebration-popup {
      padding: 1rem 1rem 1.5rem;
    }

    .celebration-popup__panel {
      width: 100%;
    }

    .celebration-popup__content {
      gap: 1rem;
    }

    .celebration-popup__text {
      width: min(100%, 36rem);
    }

    .celebration-popup__title {
      font-size: 1.05rem;
    }

    .celebration-popup__message {
      font-size: 0.92rem;
      line-height: 1.55;
    }
  }
</style>
