---
// Footer.astro
import { getAssetUrl } from "../utils/cdn";
---

<div data-variant-host>
  <template data-variant="desktop">
    <footer id="footer" class="relative w-full overflow-hidden m-0 p-0 flex flex-col">
      <div
        class="hidden md:block w-full max-w-[1438px] h-0 outline outline-1 outline-offset-[-0.50px] outline-white mx-auto"
      >
      </div>

      <div class="relative z-10 hidden md:flex flex-col min-h-[50vh] pb-8">
        <div class="flex-grow flex flex-col lg:flex-row items-start gap-10 lg:gap-0 justify-between px-6 lg:px-16 pt-6">
          <div class="flex-shrink-0 w-full lg:w-auto">
            <div
              class="text-yellow-50 text-xl font-bold font-['PolySans_Trial'] leading-tight"
              style="font-family: 'PolySans Bold', 'PolySans Trial', sans-serif;"
            >
              computer society<br />of india
            </div>
            <div
              class="w-fit my-4 relative flex items-center border border-zinc-100 rounded-full px-6 py-1.5 pr-8"
            >
              <!-- glowign dot -->
              <div
                class="w-3 h-3 bg-green-500 rounded-full shadow-[0_0_8px_2px_rgba(34,197,94,0.6)]
            animate-[pulse_1.5s_ease-in-out_infinite]"
              >
              </div>

              <div
                class="ml-3 text-zinc-100 text-[13px] font-thin font-['PolySans_Trial'] whitespace-nowrap"
              >
                All systems online
              </div>
            </div>

            <div class="mt-6 relative w-48 h-32 lg:w-52 lg:h-36">
              <a
                href="https://w3w.co/static.grips.limelight"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  src={getAssetUrl("/footer/VIT-Map.png")}
                  alt="VIT Map"
                  class="w-full h-full object-cover rounded-lg shadow-lg border border-zinc-700"
                  loading="lazy"
                  decoding="async"
                />
              </a>
              <div
                class="absolute inset-0 opacity-30 bg-gradient-to-b from-white to-red-500 rounded-lg pointer-events-none"
              >
              </div>
            </div>
          </div>

          <!-- Navigation Sections -->
          <div class="flex w-full lg:w-auto justify-start items-start gap-6 lg:gap-8 flex-wrap">
            <!-- About Section -->
            <div
              class="w-16 inline-flex flex-col justify-start items-start gap-4"
            >
              <div
                class="footer-section-title text-yellow-50 text-base font-light font-['PolySans_Trial'] uppercase"
              >
                About
              </div>
              <div
                class="self-stretch flex flex-col justify-start items-start gap-2"
              >
                <a
                  href="#about"
                  class="self-stretch text-white text-base font-light font-['PolySans_Trial'] uppercase hover:text-yellow-50 transition-colors"
                >
                  CSI-VIT
                </a>
                <a
                  href="https://vit.ac.in"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="self-stretch text-white text-base font-light font-['PolySans_Trial'] uppercase hover:text-yellow-50 transition-colors"
                >
                  VIT
                </a>
                <a
                  href="https://www.csi-india.org"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="self-stretch text-white text-base font-light font-['PolySans_Trial'] uppercase hover:text-yellow-50 transition-colors"
                >
                  CSI
                </a>
              </div>
            </div>

            <!-- Domains Section -->
            <div
              class="w-44 inline-flex flex-col justify-start items-start gap-4"
            >
