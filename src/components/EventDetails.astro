---
import { getAssetUrl } from "../utils/cdn";
---

<div
  id="event-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4 backdrop-blur-sm bg-black/60 transition-all duration-300 opacity-0"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div
    class="relative w-full max-w-2xl bg-[#1a1a1a] border border-[#F95F4A] rounded-xl shadow-2xl overflow-hidden transform transition-all duration-300 scale-95"
    id="modal-content"
  >
    <!-- Close Button -->
    <button
      id="modal-close"
      class="absolute top-4 right-4 text-white/70 hover:text-[#F95F4A] transition-colors z-10"
      aria-label="Close modal"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-6 h-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="flex flex-col md:flex-row h-full">
      <!-- Image Side -->
      <div
        class="w-full md:w-1/2 relative bg-black/50 min-h-[200px] md:min-h-full flex items-center justify-center p-4"
      >
        <img
          id="modal-image"
          src=""
          alt="Event Image"
          class="w-full h-auto max-h-[300px] object-contain rounded-md"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Content Side -->
      <div class="w-full md:w-1/2 p-6 md:p-8 flex flex-col justify-between">
        <div>
          <h2
            id="modal-title"
            class="text-2xl md:text-3xl font-bold font-['PolySans_Trial'] text-white mb-4 uppercase leading-none"
          >
            <!-- Title injected via JS -->
          </h2>
          <p
            id="modal-description"
            class="text-white/80 text-sm md:text-base leading-relaxed font-sans mb-6"
          >
            <!-- Description injected via JS -->
          </p>
        </div>

        <a
          id="modal-link"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block w-full text-center py-3 px-6 rounded-full bg-[#F95F4A] text-white font-bold uppercase tracking-wider hover:bg-[#ff7b69] transition-colors transform active:scale-95"
        >
          Visit Website
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // @ts-nocheck
  (function () {
    function init() {
      const modal = document.getElementById("event-modal");
      const modalContent = document.getElementById("modal-content");
      const closeBtn = document.getElementById("modal-close");
      const titleEl = document.getElementById("modal-title");
      const descEl = document.getElementById("modal-description");
      const imgEl = document.getElementById("modal-image");
      const linkEl = document.getElementById("modal-link");

      if (!modal) return;

      // Open Modal Function
      window.openEventModal = (data) => {
        // Set Content
        if (titleEl) titleEl.textContent = data.title;
        if (descEl)
          descEl.textContent = data.description || "No description available.";
        if (imgEl) imgEl.src = data.src;
        if (linkEl) linkEl.href = data.site;

        // Show
        modal.classList.remove("hidden");
        modal.style.display = "flex";

        // Small delay to allow display:flex to apply before opacity transition
        requestAnimationFrame(() => {
          modal.classList.remove("opacity-0");
          if (modalContent) modalContent.classList.remove("scale-95");
        });
        document.body.style.overflow = "hidden"; // Prevent background scroll
      };

      // Close Modal Function
      const closeModal = () => {
        modal.classList.add("opacity-0");
        if (modalContent) modalContent.classList.add("scale-95");

        setTimeout(() => {
          modal.classList.add("hidden");
          modal.style.display = "none";
          document.body.style.overflow = "";
        }, 300); // 300ms matches CSS transition duration
      };

      if (closeBtn) closeBtn.addEventListener("click", closeModal);

      // Click outside to close
      modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
      });

      // Valid Custom Event Listener for easier dispatch from other components
      document.addEventListener("open-event-modal", (e) => {
        if (e.detail) {
          window.openEventModal(e.detail);
        }
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
