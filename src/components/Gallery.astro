---
// Gallery.astro
import { getAssetUrl } from "../utils/cdn";
import ProofGallery from "./ProofGallery.astro";
---

<section
  class="gallery-section relative w-full pt-16 pb-0 sm:pt-24 sm:pb-0 overflow-hidden"
>
  <!-- Floating Words Background -->
  <div class="floating-words-container" aria-hidden="true">
    <span
      class="floating-word"
      style="--delay: 0s; --duration: 45s; --x: 5%; --y: 10%;"
      >CODEX CRYPTUM</span
    >
    <span
      class="floating-word"
      style="--delay: 3s; --duration: 55s; --x: 80%; --y: 15%;"
      >THE NEURAL HACK</span
    >
    <span
      class="floating-word"
      style="--delay: 6s; --duration: 50s; --x: 10%; --y: 35%;"
      >CRYPTIC HUNT</span
    >
    <span
      class="floating-word"
      style="--delay: 0s; --duration: 60s; --x: 70%; --y: 40%;">APPTITUDE</span
    >
    <span
      class="floating-word"
      style="--delay: 3s; --duration: 48s; --x: 25%; --y: 20%;">CODART</span
    >
    <span
      class="floating-word"
      style="--delay: 6s; --duration: 52s; --x: 85%; --y: 30%;"
      >REVERSE CODING</span
    >
    <span
      class="floating-word"
      style="--delay: 0s; --duration: 58s; --x: 2%; --y: 45%;"
      >HOUR OF CODE</span
    >
    <span
      class="floating-word"
      style="--delay: 3s; --duration: 47s; --x: 60%; --y: 10%;"
      >CODE2CREATE</span
    >
    <span
      class="floating-word"
      style="--delay: 6s; --duration: 54s; --x: 40%; --y: 5%;"
      >THE TINY HACK</span
    >
    <span
      class="floating-word"
      style="--delay: 0s; --duration: 51s; --x: 90%; --y: 25%;">CODE++</span
    >
    <span
      class="floating-word"
      style="--delay: 3s; --duration: 56s; --x: 15%; --y: 25%;">INSPIHER</span
    >
    <span
      class="floating-word"
      style="--delay: 6s; --duration: 49s; --x: 75%; --y: 5%;">FORKTOBER</span
    >
    <span
      class="floating-word"
      style="--delay: 0s; --duration: 53s; --x: 35%; --y: 40%;"
      >SUMMER BOOTCAMP</span
    >
    <span
      class="floating-word"
      style="--delay: 3s; --duration: 57s; --x: 50%; --y: 30%;"
      >LEARN2AUGMENT</span
    >
    <span
      class="floating-word"
      style="--delay: 6s; --duration: 46s; --x: 65%; --y: 20%;">UNIPOOL</span
    >
    <span
      class="floating-word"
      style="--delay: 0s; --duration: 59s; --x: 8%; --y: 15%;">CLI-TOP</span
    >
    <span
      class="floating-word"
      style="--delay: 3s; --duration: 50s; --x: 82%; --y: 45%;">CLI-RPG</span
    >
    <span
      class="floating-word"
      style="--delay: 6s; --duration: 55s; --x: 45%; --y: 15%;">EXAMCOOKER</span
    >
    <span
      class="floating-word"
      style="--delay: 0s; --duration: 48s; --x: 20%; --y: 40%;">LOCALHOST</span
    >
    <span
      class="floating-word"
      style="--delay: 3s; --duration: 52s; --x: 55%; --y: 45%;">CSI</span
    >
  </div>

  <div class="flex w-full flex-col items-center gap-3 relative z-10">
    <div class="relative flex w-full max-w-4xl flex-col items-center px-4">
      <img
        src={getAssetUrl("/gallery.webp")}
        alt="Gallery Title"
        class="gallery-title relative z-10 w-[90vw] max-w-3xl mb-2"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="px-4">
      <div
        onclick="window.openProofGallery()"
        class="w-[484px] h-12 bg-[#F95F4A] rounded-[41px] outline outline-1 outline-offset-[-1px] outline-yellow-50
           flex items-center justify-center hover:scale-105 transition-transform duration-200 cursor-pointer"
        role="button"
        tabindex="0"
      >
        <span
          class="text-white text-base font-light font-['PolySans_Trial'] uppercase"
        >
          Proof We Actually Do Stuff - View Photos!
        </span>
      </div>
    </div>

    <div class="gallery-frame relative w-full overflow-hidden">
      <img
        src={getAssetUrl("/full-core.webp")}
        alt="CSI-VIT gallery collage"
        class="gallery-image w-full object-cover"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
  <ProofGallery />
</section>

<script>
  // Ensure the function is available (if ProofGallery script hasn't run yet, though it should have)
  // Actually, Astro scripts module hoist, so it might be fine, but let's be safe.
</script>

<style>
  .gallery-section {
    font-family: "PolySans Trial", "PolySans", system-ui, sans-serif;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  .gallery-section * {
    -webkit-user-select: none;
    user-select: none;
  }

  .gallery-section img {
    -webkit-user-drag: none;
  }

  .gallery-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(3, 3, 3, 0) 40%,
      rgba(3, 3, 3, 0.55) 100%
    );
    pointer-events: none;
  }

  .gallery-image {
    filter: grayscale(1);
    transition: filter 0.3s ease;
  }

  .gallery-frame:hover .gallery-image {
    filter: grayscale(0.2);
  }

  /* Floating Words Background */
  .floating-words-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .floating-word {
    position: absolute;
    font-family: "Inter", sans-serif;
    font-size: 60.703px;
    font-weight: 900;
    font-style: normal;
    line-height: normal;
    text-transform: uppercase;
    opacity: 0.15;
    white-space: nowrap;
    letter-spacing: 0.1em;
    color: #ffffff;
    will-change: transform;
    animation: float var(--duration, 50s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
    left: var(--x, 50%);
    top: var(--y, 50%);
  }

  .floating-word:nth-child(even) {
    -webkit-text-stroke-width: 2.28px;
    -webkit-text-stroke-color: #ffffff;
    color: transparent;
    opacity: 0.1;
  }


  @keyframes float {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
    25% {
      transform: translate3d(15vw, -20vh, 0) rotate(2deg);
    }
    50% {
      transform: translate3d(-10vw, 15vh, 0) rotate(-1deg);
    }
    75% {
      transform: translate(20vw, 10vh) rotate(1deg);
    }
  }

  /* Ensure gallery content is above the floating words */
  /* The z-index on gallery-section is not strictly needed here as floating-words-container is now a child with z-index 0 and main content has z-10 */
  /* .gallery-section {
    position: relative;
    z-index: 1;
  } */

  @media (max-width: 640px) {
    .floating-word {
      font-size: clamp(1rem, 4vw, 2rem);
      opacity: 0.02;
    }
  }
</style>
