---
interface Props {
  bgurl: string;
  link: string;
}

import { getAssetUrl } from "../utils/cdn";
const { bgurl, link } = Astro.props;

const imageUrl = bgurl.startsWith("http") ? bgurl : getAssetUrl(bgurl);
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  class="relative w-full sm:w-[40vw] lg:w-[14vw] aspect-[1.6] rounded-lg bg-white overflow-hidden flex items-end justify-center cursor-pointer transition-transform duration-300 hover:scale-105"
>
  <!-- Background Pattern -->
  <img
    src={imageUrl}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    decoding="async"
  />
  <div
    class="w-[97%] h-[96.5%] flex justify-center items-center absolute z-20 pointer-events-none"
  >
    <img
      src={getAssetUrl("/bloglayout.webp")}
      alt="Background Pattern"
      class="absolute w-full h-full object-contain"
      loading="lazy"
      decoding="async"
    />
  </div>

  <style>
    @font-face {
      font-family: "PolySans Slim";
      src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-SlimMono.otf")
        format("opentype");
      font-weight: 300;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: "PolySans Trial";
      src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-NeutralMono.otf")
        format("opentype");
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: "PolySans Medium";
      src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-MedianMono.otf")
        format("opentype");
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }

    @font-face {
      font-family: "PolySans Bold";
      src: url("../assets/fonts/PolySans-trial/PolySans-trial/Mono/PolySansTrial-BulkyMono.otf")
        format("opentype");
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
  </style>
</a>
