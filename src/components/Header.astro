---
// Header.astro
---

<header
  class="site-header fixed top-5 left-0 right-0 z-50 w-full px-4 py-2 pointer-events-none"
>
  <div
    class="header-inner relative max-w-4xl mx-auto flex justify-center pointer-events-auto"
  >
    <nav>
      <!-- Desktop nav -->
      <div class="nav-desktop">
        <div
          class="header-pill relative flex items-center justify-center w-fit px-8 overflow-hidden"
          style="height:50px;border-radius:41px;border:1px solid #FEFCD9;background:rgba(0,0,0,0.35);backdrop-filter:blur(4px);"
        >
          <!-- The Blob -->
          <div
            id="nav-blob"
            class="absolute top-0 bottom-0 bg-[#F95F4A] rounded-[41px] transition-all duration-300 ease-[cubic-bezier(0.25,0.1,0.25,1)] opacity-0 -z-10"
            style="left: 0; width: 0;"
          >
          </div>

          <!-- Dynamic Title for MORE sections -->
          <div
            id="dynamic-title"
            class="absolute inset-0 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
          >
            <div
              class="justify-start text-white text-base font-light font-['PolySans_Trial'] uppercase"
            >
            </div>
          </div>

          <ul
            class="nav-list relative z-10 flex items-center gap-2 md:gap-4 text-[13.5px] md:text-[14.8px] font-mono uppercase text-white"
            style="white-space:nowrap;align-items:center;letter-spacing:0.04em;"
          >
            <li>
              <a
                href="#about"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >ABOUT</a
              >
            </li>
            <li>
              <a
                href="#domains"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >DOMAINS</a
              >
            </li>
            <li>
              <a
                href="#events"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >EVENTS</a
              >
            </li>
            <li>
              <a
                href="#projects"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >PROJECTS</a
              >
            </li>
            <li>
              <a
                href="#community"
                class="nav-link inline-block px-3 py-1 hover:text-white transition-colors"
                >COMMUNITY</a
              >
            </li>
            <li>
              <a
                href="#"
                role="button"
                class="more-toggle inline-block px-3 py-1 more-link hover:opacity-80 transition-opacity"
                aria-controls="desktopMoreMenu"
                aria-expanded="false">MORE</a
              >
            </li>
          </ul>
        </div>
      </div>

      <!-- Desktop More dropdown -->
      <div id="desktopMoreMenu" class="more-menu w-[220px]">
        <ul class="mobile-more-list">
          <li>
            <a
              href="#blogs"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Blogs</a
            >
          </li>
          <li>
            <a
              href="#partners"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Partners</a
            >
          </li>
          <li>
            <a
              href="#contact"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Contact Us</a
            >
          </li>
          <li>
            <a
              href="#community"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Community</a
            >
          </li>
          <li>
            <a
              href="#team"
              class="text-yellow-50 uppercase font-['PolySans_Trial'] text-[11px]"
              >Team</a
            >
          </li>
        </ul>
      </div>

      <!-- Mobile nav -->
      <div class="nav-mobile">
        <button
          id="mobile-menu-btn"
          class="pointer-events-auto w-12 h-12 flex items-center justify-center rounded-full bg-[rgba(0,0,0,0.35)] border border-[#FEFCD9] backdrop-blur transition-transform active:scale-95"
          aria-label="Toggle menu"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#FEFCD9"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>

        <div
          id="mobile-menu-overlay"
          class="fixed inset-0 bg-black/95 z-[100] translate-x-full transition-transform duration-300 flex flex-col items-center justify-center"
        >
          <button
            id="mobile-menu-close"
            class="absolute top-6 right-6 w-12 h-12 flex items-center justify-center text-[#FEFCD9]"
          >
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
          <ul class="flex flex-col gap-6 text-center">
            {
              [
                "about",
                "domains",
                "events",
                "projects",
                "community",
                "blogs",
                "partners",
                "contact",
                "community",
                "team",
              ].map((item) => (
                <li>
                  <a
                    href={`#${item}`}
                    class="mobile-nav-link text-3xl font-light font-['PolySans_Trial'] uppercase text-[#FEFCD9] hover:text-[#F95F4A] transition-colors"
                  >
                    {item.replace("-", " ")}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  .header-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      width 0.3s cubic-bezier(0.25, 0.1, 0.25, 1),
      background-color 0.3s ease,
      border-color 0.3s ease;
  }

  /* Dynamic Mode Styles */
  .header-pill.dynamic-mode {
    width: 112px; /* w-28 */
    background-color: #f95f4a !important;
    border-color: #fefcd9;
  }

  .header-pill.dynamic-mode.pink-mode {
    background-color: #ff007a !important;
  }

  .header-pill.dynamic-mode .nav-list {
    opacity: 0;
    pointer-events: none;
  }

  .header-pill.dynamic-mode #dynamic-title {
    opacity: 1;
  }

  /* Hover state for dynamic mode - revert to full menu */
  .header-pill.dynamic-mode:hover {
    width: var(--full-width, auto) !important;
    background-color: rgba(0, 0, 0, 0.35) !important;
    border-color: #fefcd9;
  }

  .header-pill.dynamic-mode:hover .nav-list {
    opacity: 1;
    pointer-events: auto;
    transition-delay: 0.1s;
  }

  .header-pill.dynamic-mode:hover #dynamic-title {
    opacity: 0;
    transition-delay: 0s;
  }
  .nav-list a {
    position: relative;
    z-index: 10;
    color: #fefcd9;
    transition: color 0.3s ease;
  }
  .nav-list a.more-link {
    color: #f95f4a !important;
  }
  .nav-list li {
    white-space: nowrap;
  }
  .nav-desktop {
    display: block;
    position: relative;
    transform: scale(var(--nav-bar-scale, 1));
    transform-origin: top center;
    transition: transform 160ms ease;
  }
  .nav-mobile {
    display: none;
    position: relative;
    pointer-events: auto; /* Ensure button is clickable */
  }

  /* 'More' dropdown */
  .more-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0; /* stick to right */
    left: auto;
    border: 1px solid #fefcd9;
    border-radius: 16px;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(4px);
    padding: 10px 12px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.25);
    z-index: 60;
    /* animation base state */
    opacity: 0;
    transform: translateY(8px) scale(0.96);
    transform-origin: top right;
    transition:
      opacity 0.18s ease,
      transform 0.24s cubic-bezier(0.22, 0.61, 0.36, 1);
    pointer-events: none;
  }
  .more-menu.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .mobile-more-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 6px;
    text-align: left;
  }
  .mobile-more-list a {
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .more-menu .mobile-more-list li {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.2s ease,
      transform 0.25s ease;
  }
  .more-menu.open .mobile-more-list li {
    opacity: 1;
    transform: translateY(0);
  }
  .more-menu.open .mobile-more-list li:nth-child(1) {
    transition-delay: 0.02s;
  }
  .more-menu.open .mobile-more-list li:nth-child(2) {
    transition-delay: 0.06s;
  }
  .more-menu.open .mobile-more-list li:nth-child(3) {
    transition-delay: 0.1s;
  }

  @media (max-width: 952px) {
    body.partners-active .site-header {
      z-index: 200;
    }
    body.mobile-menu-open #mobile-menu-btn {
      opacity: 0;
      pointer-events: none;
    }
    .site-header {
      top: 15px;
      bottom: auto;
      padding: 0 15px;
    }
    .header-inner {
      justify-content: flex-end;
    }
    body.hero-in-view .site-header {
      top: auto;
      bottom: calc(18px + env(safe-area-inset-bottom, 0px));
    }
    body.hero-in-view .header-inner {
      justify-content: center;
    }
    #mobile-menu-btn,
    #mobile-menu-close {
      width: 45px;
      height: 45px;
    }
    #mobile-menu-close {
      top: 15px;
      right: 15px;
      bottom: auto;
      left: auto;
      transform: none;
    }
    body.hero-in-view #mobile-menu-close {
      top: auto;
      right: auto;
      bottom: calc(18px + env(safe-area-inset-bottom, 0px));
      left: 50%;
      transform: translateX(-50%);
    }
    .nav-desktop {
      display: none;
      transform: none;
    }
    .nav-mobile {
      display: block;
    }
  }

  @media screen and (max-width: 480px) {
    .site-header {
      top: 10px;
      padding: 0 10px;
    }
    body.hero-in-view .site-header {
      top: auto;
      bottom: calc(10px + env(safe-area-inset-bottom, 0px));
    }
    #mobile-menu-btn,
    #mobile-menu-close {
      width: 35px;
      height: 35px;
    }
    #mobile-menu-btn svg,
    #mobile-menu-close svg {
      width: 20px;
      height: 20px;
    }
    #mobile-menu-close {
      top: 10px;
      right: 10px;
    }
    body.hero-in-view #mobile-menu-close {
      top: auto;
      right: auto;
      bottom: calc(10px + env(safe-area-inset-bottom, 0px));
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener("DOMContentLoaded", () => {
    // BLOB NAVIGATION LOGIC
    const blob = document.getElementById("nav-blob");
    const navLinks = document.querySelectorAll(".nav-desktop .nav-link");
    const sections = document.querySelectorAll("section[id], footer[id]"); // Include footer
    const moreToggle = document.querySelector(".nav-desktop .more-toggle");
    const pill = document.querySelector(".header-pill");
    const dynamicTitle = document.querySelector("#dynamic-title div"); // Changed to div

    // Mobile Menu Logic
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");
    const mobileMenuClose = document.getElementById("mobile-menu-close");
    const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

    function toggleMobileMenu(show) {
      if (show) {
        mobileMenuOverlay.classList.remove("translate-x-full");
        document.body.classList.add("mobile-menu-open");
      } else {
        mobileMenuOverlay.classList.add("translate-x-full");
        document.body.classList.remove("mobile-menu-open");
      }
    }

    if (mobileMenuBtn) {
      mobileMenuBtn.addEventListener("click", () => toggleMobileMenu(true));
    }
    if (mobileMenuClose) {
      mobileMenuClose.addEventListener("click", () => toggleMobileMenu(false));
    }
    mobileNavLinks.forEach((link) => {
      link.addEventListener("click", () => toggleMobileMenu(false));
    });

    // Capture initial full width for restoration
    let fullWidth = pill ? pill.offsetWidth : 0;
    if (pill) {
      pill.style.setProperty("--full-width", `${fullWidth}px`);
      // Update full width on resize
      window.addEventListener("resize", () => {
        // Temporarily remove dynamic class to measure
        const wasDynamic = pill.classList.contains("dynamic-mode");
        if (wasDynamic) pill.classList.remove("dynamic-mode");

        const navList = document.querySelector(".nav-list");
        if (navList) {
          // 32px padding-left + 32px padding-right (px-8 = 2rem = 32px)
          const w = navList.offsetWidth + 64;
          pill.style.setProperty("--full-width", `${w}px`);
        }

        if (wasDynamic) pill.classList.add("dynamic-mode");
        currentSectionId = null;
        scheduleNavUpdate();
      });
    }

    // IDs that live under the "MORE" dropdown
    const moreSectionIds = [
      "blogs",
      "partners",
      "contact",
      "community",
      "team",
    ];
    const idMapping = {
      work: "events",
      "igniting-minds-section": "about",
      "projects-intro": "projects",
      "community-outreach": "community",
      "community-sdg": "community",
      "community-conduct": "community",
      "community-speaker": "community",
    };
    let currentSectionId = null;
    let rafPending = false;
    let lastScrollY = window.scrollY || window.pageYOffset;
    let scrollDirection = "down";

    // Function to update blob position
    function updateBlob(targetLink) {
      if (!targetLink || !blob) return;

      const pill = document.querySelector(".header-pill");
      if (!pill) return;

      const pillRect = pill.getBoundingClientRect();
      const linkRect = targetLink.getBoundingClientRect();
      const scaleX = pill.offsetWidth > 0 ? pillRect.width / pill.offsetWidth : 1;
      const safeScaleX = Number.isFinite(scaleX) && scaleX > 0 ? scaleX : 1;

      const relativeLeft = (linkRect.left - pillRect.left) / safeScaleX;
      const width = linkRect.width / safeScaleX;

      blob.style.left = `${relativeLeft}px`;
      blob.style.width = `${width}px`;
      blob.style.opacity = "1";

      // Color logic
      const href = targetLink.getAttribute("href");
      if (href === "#community") {
        blob.style.backgroundColor = "#FF007A";
      } else {
        blob.style.backgroundColor = "#F95F4A";
      }
    }

    // Function to hide blob
    function hideBlob() {
      if (blob) blob.style.opacity = "0";
    }

    function setDynamicMode(isDynamic, sectionId) {
      if (!pill) return;

      if (isDynamic) {
        pill.classList.add("dynamic-mode");
        if (sectionId === "community") {
          pill.classList.add("pink-mode");
        } else {
          pill.classList.remove("pink-mode");
        }

        if (dynamicTitle) {
          let text = sectionId;
          let isLongText = false;

          if (sectionId.startsWith("community-")) {
            // Format: Community: Outreach
            const sub = sectionId.replace("community-", "");
            let displaySub = sub;
            if (sub === "outreach") displaySub = "Outreach";
            else if (sub === "sdg") displaySub = "SDG";
            else if (sub === "conduct") displaySub = "Code of Conduct";
            else if (sub === "speaker") displaySub = "Speakers";

            text = `Community: ${displaySub}`;
            isLongText = true;
          }

          dynamicTitle.textContent = text;
          dynamicTitle.style.whiteSpace = "nowrap";

          if (isLongText) {
            // Measure text width
            const font = "16px PolySans_Trial";
            const tempSpan = document.createElement("span");
            tempSpan.style.fontFamily = "'PolySans_Trial', sans-serif";
            tempSpan.style.fontSize = "16px";
            tempSpan.style.fontWeight = "300";
            tempSpan.style.textTransform = "uppercase";
            tempSpan.style.visibility = "hidden";
            tempSpan.style.position = "absolute";
            tempSpan.style.whiteSpace = "nowrap";
            tempSpan.textContent = text;
            document.body.appendChild(tempSpan);
            const width = tempSpan.offsetWidth;
            document.body.removeChild(tempSpan);

            const totalWidth = width + 55;

            pill.style.setProperty("width", `${totalWidth}px`);
            pill.style.setProperty("padding-left", "0px"); // Reset to avoid double padding if width includes it? Actually my logic sets width including padding.
            // Wait, transition: width 0.3s. If I set width explicit, it should animate.
          } else {
            pill.style.setProperty("width", "112px");
          }
        }
        hideBlob();
      } else {
        pill.classList.remove("dynamic-mode");
        pill.classList.remove("pink-mode");
        // Clear inline styles so it returns to original CSS/auto width
        pill.style.removeProperty("width");
        pill.style.removeProperty("padding-left");
      }
    }

    function applyNavState(sectionId) {
      if (!sectionId) return;

      if (sectionId === "footer") {
        setDynamicMode(false);
        hideBlob();
        return;
      }

      if (moreSectionIds.includes(sectionId) || sectionId.startsWith("community-")) {
        setDynamicMode(true, sectionId);
        return;
      }

      const mappedId = idMapping[sectionId] || sectionId;
      setDynamicMode(false);

      const activeLink = document.querySelector(
        `.nav-desktop .nav-link[href="#${mappedId}"]`
      );
      if (activeLink) {
        updateBlob(activeLink);
      } else {
        hideBlob();
      }
    }

    function getActiveSection() {
      const focusLine = window.innerHeight * 0.3;
      let activeSection = null;
      let closestSection = null;
      let closestDistance = Infinity;
      let closestPosition = null;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= focusLine && rect.bottom >= focusLine) {
          activeSection = section;
        }
        let distance = 0;
        let position = null;
        if (rect.top > focusLine) {
          distance = rect.top - focusLine;
          position = "below";
        } else if (rect.bottom < focusLine) {
          distance = focusLine - rect.bottom;
          position = "above";
        }

        if (distance < closestDistance) {
          closestDistance = distance;
          closestSection = section;
          closestPosition = position;
        } else if (distance === closestDistance && closestSection) {
          if (
            scrollDirection === "down" &&
            position === "below" &&
            closestPosition !== "below"
          ) {
            closestSection = section;
            closestPosition = position;
          } else if (
            scrollDirection === "up" &&
            position === "above" &&
            closestPosition !== "above"
          ) {
            closestSection = section;
            closestPosition = position;
          }
        }
      });

      return activeSection || closestSection;
    }

    function updateActiveSection() {
      rafPending = false;
      const scrollY = window.scrollY || window.pageYOffset;
      if (scrollY !== lastScrollY) {
        scrollDirection = scrollY > lastScrollY ? "down" : "up";
        lastScrollY = scrollY;
      }
      const activeSection = getActiveSection();
      if (!activeSection) return;
      const id = activeSection.getAttribute("id");
      if (!id || id === currentSectionId) return;
      currentSectionId = id;
      applyNavState(id);
    }

    function scheduleNavUpdate() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(updateActiveSection);
    }

    // Intersection Observer to track sections
    const observerOptions = {
      root: null,
      rootMargin: "-20% 0px -60% 0px", // Trigger when section is near top/center
      threshold: 0,
    };

    const observer = new IntersectionObserver(() => {
      scheduleNavUpdate();
    }, observerOptions);

    sections.forEach((section) => observer.observe(section));
    window.addEventListener("scroll", scheduleNavUpdate, { passive: true });

    // Removed manual hover listener as requested

    // EXISTING DROPDOWN LOGIC
    const toggles = Array.from(document.querySelectorAll(".more-toggle"));
    const moreMenuLinks = document.querySelectorAll("#desktopMoreMenu a");

    const getMenuFor = (tg) => {
      const id = tg.getAttribute("aria-controls");
      return id ? document.getElementById(id) : null;
    };

    const openMenu = (tg, menu) => {
      tg.setAttribute("aria-expanded", "true");
      menu.classList.add("open");
    };

    const closeMenu = (tg, menu) => {
      tg.setAttribute("aria-expanded", "false");
      menu.classList.remove("open");
    };

    const allMenus = () => toggles.map(getMenuFor).filter(Boolean);

    const closeAll = () =>
      toggles.forEach((tg) => {
        const m = getMenuFor(tg);
        if (m) closeMenu(tg, m);
      });

    let suppressNextDocClick = false;

    toggles.forEach((tg) => {
      const menu = getMenuFor(tg);
      if (!menu) return;
      tg.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        suppressNextDocClick = true;
        setTimeout(() => {
          suppressNextDocClick = false;
        }, 0);
        const expanded = tg.getAttribute("aria-expanded") === "true";
        toggles.forEach((ot) => {
          if (ot !== tg) {
            const otherMenu = getMenuFor(ot);
            if (otherMenu) closeMenu(ot, otherMenu);
          }
        });
        if (expanded) {
          closeMenu(tg, menu);
        } else {
          openMenu(tg, menu);
        }
      });

      let hoverTimer = null;
      const startCloseTimer = () => {
        hoverTimer = setTimeout(() => {
          closeMenu(tg, menu);
        }, 220);
      };
      const clearCloseTimer = () => {
        if (hoverTimer) {
          clearTimeout(hoverTimer);
          hoverTimer = null;
        }
      };

      tg.addEventListener("mouseenter", () => {
        openMenu(tg, menu);
      });
      tg.addEventListener("mouseleave", () => {
        startCloseTimer();
      });
      menu.addEventListener("mouseenter", () => {
        clearCloseTimer();
      });
      menu.addEventListener("mouseleave", () => {
        startCloseTimer();
      });
    });

    moreMenuLinks.forEach((link) => {
      link.addEventListener("click", () => {
        closeAll();
      });
    });

    document.addEventListener("click", (e) => {
      if (suppressNextDocClick) return;
      const t = e.target;
      if (!(t instanceof Node)) return;
      const withinToggle = toggles.some((tg) => tg.contains(t));
      const withinMenu = allMenus().some((m) => m.contains(t));
      if (!withinToggle && !withinMenu) closeAll();
    });

    // Smooth-scroll
    document.addEventListener("click", (e) => {
      const el =
        e.target instanceof Element ? e.target.closest('a[href^="#"]') : null;
      if (!el) return;
      const href = el.getAttribute("href");
      if (!href || href.length < 2) return;
      const id = href.slice(1);
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      closeAll();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
      history.replaceState(null, "", `#${id}`);

      // Manually update blob on click
      applyNavState(id);
      currentSectionId = id;
    });
    scheduleNavUpdate();
  });
</script>
