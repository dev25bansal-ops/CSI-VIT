---
// CSI-W Content
import { getAssetUrl } from "../utils/cdn";
---

<section
  class="min-h-screen w-full relative flex flex-col justify-center items-center text-white py-8 px-6 md:py-12 md:px-12 uppercase"
>
  <div
    class="h-dvh flex flex-col items-center justify-center relative z-20 gap-10"
  >
    <div class="flex items-center justify-center relative px-16">
      <img
        id="tubelight"
        src={getAssetUrl("/pink_tubelight.png")}
        alt="pink light"
        class="w-[80vw] max-w-[1400px] opacity-0 select-none absolute z-[-1]
                    [mask-image:radial-gradient(circle,black_30%,transparent_100%)]
                    [mask-repeat:no-repeat]
                    [mask-position:center]
                    [mask-size:contain]
                    will-change-opacity
                    max-[480px]:w-[95vw] max-[480px]:max-w-none max-[480px]:left-1/2 max-[480px]:-translate-x-1/2"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="flex items-center gap-10">
      <img
        src={getAssetUrl("/csiw-logo.webp")}
        alt="CSI-W Logo"
        class="w-[30vw] h-auto max-[480px]:!w-[45vw] max-[480px]:max-w-none"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div
      class="text-left text-white text-base leading-relaxed max-w-4xl font-polysans
                max-[640px]:text-[0.95rem] max-[640px]:leading-[1.45] max-[640px]:max-w-[28rem]
                max-[480px]:text-[0.85rem] max-[480px]:leading-[1.4]"
    >
      <span class="text-primary-pink"
        >Computer Society of India (CSI) promotes women in technology through
        its Empowering Women in IT (eWIT) initiative and various recognition
        programs.<br />
        Founded in March 2006, eWIT is a voluntary, not-for-profit forum run
        by senior women IT professionals, addressing the need to increase the
        share and sustainability of women in the IT/ITES industry.<br /></span
      ><br />
      CSI fosters a community that values contributions across all computing
      fields, organizing conferences, seminars, and workshops focused on
      diversity and inclusion in technology. Through mentorship programs,
      technical events, and networking opportunities, CSI empowers women to
      take initiative, share their ideas, and thrive in computing fields.<br />
      We stand for inclusion, professional growth, and creating equal access
      to opportunities in technology.
    </div>

    <!-- Learn More Button -->
    <a
      href="https://www.csi-india.org"
      target="_blank"
      rel="noopener noreferrer"
      class="border border-primary-pink text-white px-8 py-3 rounded-full text-sm hover:cursor-pointer hover:scale-105 transition-transform duration-300 ease-in-out font-polysans
                max-[640px]:text-[0.85rem]
                max-[480px]:py-[0.55rem] max-[480px]:px-4 max-[480px]:text-[0.8rem]
                inline-block text-center"
    >
      LEARN MORE
    </a>
  </div>
</section>

<style>
  .font-polysans {
    font-family: "PolySans Trial";
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const tubelight = document.getElementById("tubelight");

    if (tubelight) {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: tubelight,
          start: "top 80%",
          end: "top 50%",
          scrub: false,
          once: true,
        },
      });

      // Flickering effect
      tl.to(tubelight, {
        opacity: 0.3,
        duration: 0.05,
        ease: "none",
      })
        .to(tubelight, {
          opacity: 0,
          duration: 0.05,
          ease: "none",
        })
        .to(tubelight, {
          opacity: 0.5,
          duration: 0.08,
          ease: "none",
        })
        .to(tubelight, {
          opacity: 0.1,
          duration: 0.05,
          ease: "none",
        })
        .to(tubelight, {
          opacity: 0.6,
          duration: 0.1,
          ease: "none",
        })
        .to(tubelight, {
          opacity: 0.2,
          duration: 0.06,
          ease: "none",
        })
        .to(tubelight, {
          opacity: 0.7,
          duration: 0.12,
          ease: "none",
        })
        .to(tubelight, {
          opacity: 0.3,
          duration: 0.05,
          ease: "none",
        })
        //final glow
        .to(tubelight, {
          opacity: 0.8,
          duration: 0.3,
          ease: "power2.out",
        })
        .to(tubelight, {
          opacity: 0.75,
          duration: 0.15,
          ease: "sine.inOut",
          yoyo: true,
          repeat: 1,
        });
    }
  });
</script>
