---
import ArrowButton from "../../public/button_arrow.webp";
import { getAssetUrl } from "../utils/cdn";

const fallbackEmail = "hello@csivitchennai.in";
const rawEndpoint = (import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "").trim();
const formAction = rawEndpoint ? undefined : `mailto:${fallbackEmail}`;
---

<section class="page-section w-full px-4 py-16">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-8">
    <div class="text-center">
      <div
        class="justify-start text-white text-5xl font-semibold font-['PolySans_Trial'] uppercase"
      >
        Contact us!
      </div>
    </div>

    <div class="contact-laptop-wrapper relative w-full">
      <img
        src={getAssetUrl("/MacBook Pro 15.webp")}
        alt="MacBook contact screen"
        class="contact-laptop-img"
        loading="lazy"
        decoding="async"
      />

      <div class="contact-screen absolute pointer-events-none">
        <div class="flex flex-col items-center text-black mb-2">
          <div
            class="text-center justify-start text-stone-900 text-4xl font-bold font-['Nunito_Sans']"
          >
            Say Hello!
          </div>
        </div>

        <form
          class="contact-form pointer-events-auto mt-1 flex w-full flex-col gap-2 text-sm text-black px-8"
          method="POST"
          action={formAction}
          data-endpoint={rawEndpoint}
          data-contact-form="true"
        >
          <div class="contact-grid grid gap-2 sm:grid-cols-2">
            <label
              class="flex flex-col gap-1 text-[10px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-xs"
            >
              First Name
              <input
                type="text"
                name="firstName"
                required
                class="contact-input"
              />
            </label>
            <label
              class="flex flex-col gap-1 text-[10px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-xs"
            >
              Last Name
              <input type="text" name="lastName" class="contact-input" />
            </label>
          </div>

          <div class="contact-grid grid gap-2 sm:grid-cols-2">
            <label
              class="flex flex-col gap-1 text-[10px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-xs"
            >
              Email
              <input type="email" name="email" required class="contact-input" />
            </label>
            <label
              class="flex flex-col gap-1 text-[10px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-xs"
            >
              Phone
              <input
                type="tel"
                name="phone"
                inputmode="tel"
                pattern="^[0-9+()\s-]{7,}$"
                class="contact-input"
              />
            </label>
          </div>

          <label
            class="flex flex-col gap-1 text-[10px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-xs"
          >
            Message
            <textarea
              name="message"
              rows="2"
              required
              class="contact-input resize-none py-2"></textarea>
          </label>

          <div class="flex items-center justify-between gap-2 text-black">
            <span
              class="text-[10px] font-semibold uppercase tracking-[0.35em] text-neutral-500 sm:text-xs shrink-0"
            >
              Book a One-on-One session?
            </span>
            <div class="flex gap-2 sm:gap-4 shrink-0">
              <label class="cursor-pointer relative">
                <input
                  type="radio"
                  name="sessionPreference"
                  value="yes"
                  class="peer sr-only"
                  required
                />
                <div
                  class="w-24 h-8 sm:w-32 sm:h-9 relative rounded-[10px] opacity-80 peer-checked:opacity-100 transition-opacity hover:opacity-100"
                >
                  <div
                    class="w-full h-full left-0 top-0 absolute bg-yellow-50 rounded-[10px]"
                  >
                  </div>
                  <div
                    class="left-0 right-0 top-[2px] absolute text-center text-black text-xl sm:text-2xl font-normal font-['Trap']"
                  >
                    Yes
                  </div>
                </div>
              </label>

              <label class="cursor-pointer relative">
                <input
                  type="radio"
                  name="sessionPreference"
                  value="no"
                  class="peer sr-only"
                />
                <div
                  class="w-24 h-8 sm:w-32 sm:h-9 relative rounded-[10px] opacity-80 peer-checked:opacity-100 transition-opacity hover:opacity-100"
                >
                  <div
                    class="w-full h-full left-0 top-0 absolute bg-stone-900 rounded-[10px]"
                  >
                  </div>
                  <div
                    class="left-0 right-0 top-[2px] absolute text-center text-white text-xl sm:text-2xl font-normal font-['Trap']"
                  >
                    No
                  </div>
                </div>
              </label>
            </div>
          </div>

          <div class="flex flex-col items-center gap-1 sm:gap-2 mt-2">
            <div
              class="w-72 h-14 bg-stone-900 rounded-[200px] flex items-center justify-center overflow-hidden"
            >
              <button
                type="submit"
                class="group inline-flex items-center justify-center gap-3 w-full h-full text-2xl font-light text-[#ffeead] sm:text-3xl hover:bg-white/5 transition-colors"
              >
                Submit
                <ArrowButton
                  class="h-8 w-8 sm:h-10 sm:w-10 transition group-hover:translate-x-1"
                />
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-laptop-wrapper {
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact-laptop-img {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 35px 80px rgba(0, 0, 0, 0.55));
  }

  .contact-screen {
    left: 11%;
    top: 11%;
    width: 78%;
    height: 72%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .contact-form {
    height: 100%;
    /* overflow-y: auto; removed to avoid scrolling */
  }

  .contact-input {
    border-radius: 1.25rem;
    border: 2px dashed #050505;
    background: transparent;
    padding: 0.65rem 1rem;
    font-size: 1rem;
    font-weight: 500;
    color: #050505;
    outline: none;
    transition: border 0.2s ease;
  }

  .contact-input:focus {
    border-color: #f95f4a;
  }

  .contact-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.2rem;
    border-radius: 999px;
    border: 2px dashed #050505;
    font-size: 0.9rem;
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .contact-screen {
      left: 15%;
      top: 18.5%;
      width: 70%;
      height: 58%;
    }
  }

  @media (max-width: 768px) {
    .contact-laptop-wrapper {
      padding: 0 0.5rem;
    }

    .contact-screen {
      left: 12%;
      top: 20%;
      width: 76%;
      height: 54%;
    }

    .contact-form {
      gap: 0.6rem;
    }

    .contact-pill {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 768px) {
    .contact-screen {
      left: 9%;
      top: 21%;
      width: 82%;
      height: 52%;
    }

    .contact-input {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 400px) {
    .contact-screen {
      left: 7%;
      top: 23%;
      width: 86%;
      height: 50%;
    }
  }
</style>

<script type="module">
  const forms = document.querySelectorAll('[data-contact-form="true"]');

  forms.forEach((form) => {
    const status = form.querySelector("[data-form-status]");
    const endpoint = form.dataset.endpoint?.trim();

    if (!endpoint) {
      if (status) {
        form.addEventListener("submit", () => {
          status.textContent = "Opening your default mail app...";
          status.dataset.state = "pending";
        });
      }
      return;
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!form.reportValidity()) {
        if (status) {
          status.textContent = "Please complete all required fields.";
          status.dataset.state = "error";
        }
        return;
      }

      if (status) {
        status.textContent = "Sending your message...";
        status.dataset.state = "pending";
      }

      const payload = Object.fromEntries(new FormData(form).entries());

      try {
        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        if (!response.ok) throw new Error("Request failed");

        form.reset();
        if (status) {
          status.textContent = "Thanks! We will get back shortly.";
          status.dataset.state = "success";
        }
      } catch (error) {
        if (status) {
          status.textContent = "Unable to send. Please email hello@csivitchennai.in.";
          status.dataset.state = "error";
        }
      }
    });
  });
</script>
